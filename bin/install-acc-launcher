#!/usr/bin/env bash
set -euo pipefail

installer_script="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
  resolved_installer_script="$(readlink -f "$installer_script" 2>/dev/null || printf '%s' "$installer_script")"
else
  resolved_installer_script="$installer_script"
fi
installer_bin_dir="$(cd "${resolved_installer_script%/*}" && pwd -P)"
project_root="${installer_bin_dir%/bin}"
ui_script="$project_root/bin/pack-opener-ui"
target_dir="$HOME/.local/bin"
target_acc="$target_dir/acc"
marker="ACC global launcher generated by bin/install-acc-launcher"

if ! test -x "$ui_script"; then
  printf 'Could not find executable ACC UI:\n%s\n' "$ui_script" >&2
  exit 1
fi

mkdir -p "$target_dir"

if test -L "$target_acc"; then
  rm -f "$target_acc"
elif test -e "$target_acc"; then
  if test -f "$target_acc" && grep -qF "$marker" "$target_acc" 2>/dev/null; then
    :
  else
    printf 'Refusing to overwrite an existing acc file not created by ACC:\n%s\n' "$target_acc" >&2
    printf 'Move it out of the way, then run this installer again.\n' >&2
    exit 1
  fi
fi

tmp_file="${target_acc}.tmp.$$"
{
  printf '#!/usr/bin/env bash\n'
  printf '# %s\n' "$marker"
  printf 'exec %q "$@"\n' "$ui_script"
} > "$tmp_file"
chmod +x "$tmp_file"
mv "$tmp_file" "$target_acc"

printf 'Installed global acc launcher.\n'
printf '%s now runs:\n%s\n' "$target_acc" "$ui_script"

case ":$PATH:" in
  *":$target_dir:"*)
    printf '\nCheck it with:\ncommand -v acc\n'
    printf 'Then launch ACC with:\nacc\n'
    ;;
  *)
    printf '\n%s is not on PATH.\n' "$target_dir"
    printf 'Add this line to your shell profile, then open a new terminal:\n'
    printf 'export PATH="$HOME/.local/bin:$PATH"\n'
    printf 'Then check it with:\ncommand -v acc\n'
    ;;
esac

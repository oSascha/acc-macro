#!/usr/bin/env bash
set -euo pipefail

# ACC Setup Wizard — guides new Pop!_OS users through installing dependencies,
# creating local config, and running non-live validation.

# ── Path resolution ───────────────────────────────────────────────────────────

setup_script="${BASH_SOURCE[0]}"
setup_bin_dir="$(cd "${setup_script%/*}" && pwd -P)"
project_root="${setup_bin_dir%/bin}"

# ── Global state ──────────────────────────────────────────────────────────────

DRY_RUN=0
CHECK_ONLY=0

OS_PRETTY="Unknown"
IS_UBUNTU_LIKE=0
HAS_APT=0

DEPS_MISSING=()
SOBER_INSTALLED=0
PROFILE_SELECTED=""
LAUNCHER_INSTALLED=0

RC_DIR="$project_root/runtime_config"

# ── Helpers ───────────────────────────────────────────────────────────────────

print_header() {
  printf '\n\033[1;34m=== %s ===\033[0m\n\n' "$1"
}

print_ok() {
  printf '  \033[1;32m[OK]\033[0m   %s\n' "$1"
}

print_warn() {
  printf '  \033[1;33m[WARN]\033[0m %s\n' "$1"
}

print_miss() {
  printf '  \033[1;31m[MISS]\033[0m %s\n' "$1"
}

print_info() {
  printf '         %s\n' "$1"
}

ask_yes_no() {
  local prompt="$1"
  local default="${2:-y}"
  local answer
  while true; do
    if test "$default" = "y"; then
      printf '%s [Y/n]: ' "$prompt"
    else
      printf '%s [y/N]: ' "$prompt"
    fi
    read -r answer
    answer="${answer:-$default}"
    case "$answer" in
      [Yy]*) return 0 ;;
      [Nn]*) return 1 ;;
      *) printf 'Please answer yes or no.\n' ;;
    esac
  done
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

# ── OS detection ──────────────────────────────────────────────────────────────

detect_os() {
  if test -f /etc/os-release; then
    local os_id id_like
    os_id="$(. /etc/os-release && printf '%s' "${ID:-unknown}")"
    id_like="$(. /etc/os-release && printf '%s' "${ID_LIKE:-}")"
    OS_PRETTY="$(. /etc/os-release && printf '%s' "${PRETTY_NAME:-$os_id}")"
    case "$os_id" in
      pop|ubuntu|debian|linuxmint)
        IS_UBUNTU_LIKE=1
        ;;
      *)
        case "$id_like" in
          *ubuntu*|*debian*)
            IS_UBUNTU_LIKE=1
            ;;
        esac
        ;;
    esac
  fi
  if command_exists apt; then
    HAS_APT=1
  fi
}

# ── Dependency check ──────────────────────────────────────────────────────────

DEPS_REQUIRED=(bash git python3 xdotool flatpak gamescope grep sed)
DEPS_OPTIONAL=(wl-copy xdg-open gawk awk)

OPENCV_AVAILABLE=0

check_dependencies() {
  DEPS_MISSING=()
  local dep
  for dep in "${DEPS_REQUIRED[@]}"; do
    if command_exists "$dep"; then
      print_ok "$dep — Installed"
    else
      print_miss "$dep — Missing"
      DEPS_MISSING+=("$dep")
    fi
  done
  printf '\n'
  print_info "Optional programs:"
  for dep in "${DEPS_OPTIONAL[@]}"; do
    if command_exists "$dep"; then
      print_ok "$dep — Installed"
    else
      print_warn "$dep — Missing (not required, ACC falls back gracefully)"
    fi
  done
  printf '\n'
  print_info "Event Voter (optional):"
  if python3 -c "import cv2" 2>/dev/null; then
    OPENCV_AVAILABLE=1
    print_ok "python3-opencv — Installed (Event Voter can use visual detection)"
  else
    OPENCV_AVAILABLE=0
    print_warn "python3-opencv — Not installed (Event Voter visual detection disabled)"
    print_info "         Install: sudo apt install python3-opencv  (Pop!/Ubuntu)"
    print_info "                  sudo dnf install python3-opencv  (Fedora)"
    print_info "         Event Voter will remain disabled by default until installed."
  fi

  printf '\n'
  if test "${#DEPS_MISSING[@]}" -eq 0; then
    print_ok "All required programs are installed."
  else
    print_warn "Missing required programs: ${DEPS_MISSING[*]}"
  fi
}

# ── Install missing dependencies ──────────────────────────────────────────────

install_dependencies() {
  if test "${#DEPS_MISSING[@]}" -eq 0; then
    print_info "Nothing to install — all required programs are already present."
    return 0
  fi

  print_header "Step 3 — Install missing programs"

  if test "$DRY_RUN" = "1"; then
    print_info "[dry-run] Would offer to run:"
    print_info "  sudo apt update"
    print_info "  sudo apt install -y bash coreutils git grep sed gawk python3 python3-opencv xdotool xdg-utils flatpak gamescope wl-clipboard"
    return 0
  fi

  if test "$HAS_APT" = "0"; then
    print_warn "apt package manager not found."
    print_info "Please install the following programs using your package manager:"
    print_info "  bash coreutils git grep sed gawk python3 python3-opencv xdotool xdg-utils flatpak gamescope wl-clipboard"
    return 0
  fi

  print_info "The following command will be used to install missing programs:"
  print_info ""
  print_info "  sudo apt update"
  print_info "  sudo apt install -y bash coreutils git grep sed gawk python3 python3-opencv xdotool xdg-utils flatpak gamescope wl-clipboard"
  print_info ""
  print_info "You may be asked for your password."
  print_info ""

  if ask_yes_no "Install missing programs now?" "y"; then
    sudo apt update
    sudo apt install -y bash coreutils git grep sed gawk python3 python3-opencv xdotool xdg-utils flatpak gamescope wl-clipboard
    print_ok "Install complete."
  else
    print_warn "Skipped. Install missing programs before running the macro live."
  fi
}

# ── Sober check ───────────────────────────────────────────────────────────────

check_sober() {
  if command_exists flatpak && flatpak list 2>/dev/null | grep -q "org.vinegarhq.Sober"; then
    SOBER_INSTALLED=1
    print_ok "Sober (org.vinegarhq.Sober) — Installed"
  else
    SOBER_INSTALLED=0
    print_miss "Sober (org.vinegarhq.Sober) — Not installed"
  fi
}

install_sober() {
  if test "$SOBER_INSTALLED" = "1"; then
    print_info "Sober is already installed. Nothing to do."
    return 0
  fi

  if test "$DRY_RUN" = "1"; then
    print_info "[dry-run] Would offer to run:"
    print_info "  flatpak install -y flathub org.vinegarhq.Sober"
    return 0
  fi

  print_info "Sober is the Roblox client that runs on Linux via Flatpak."
  print_info "This will run:"
  print_info "  flatpak install -y flathub org.vinegarhq.Sober"
  print_info ""

  if ask_yes_no "Install Sober now?" "y"; then
    flatpak install -y flathub org.vinegarhq.Sober
    SOBER_INSTALLED=1
    print_ok "Sober installed."
  else
    print_warn "Skipped. You must install Sober before running the macro live."
    print_info "Run manually: flatpak install flathub org.vinegarhq.Sober"
  fi
}

# ── Runtime config setup ──────────────────────────────────────────────────────

setup_runtime_config() {
  print_header "Step 5 — Set up your local config folder (runtime_config/)"

  print_info "ACC stores your personal settings in runtime_config/."
  print_info "This folder is gitignored — it stays private on your computer."
  print_info "It is never committed to git."
  print_info ""

  if test "$DRY_RUN" = "1"; then
    if test -d "$RC_DIR"; then
      print_info "[dry-run] runtime_config/ already exists."
      print_info "[dry-run] Would ask: keep, back up, or fill in missing files."
    else
      print_info "[dry-run] runtime_config/ does not exist."
      print_info "[dry-run] Would create it and ask which starting config to use."
    fi
    print_info "[dry-run] Would then ask:"
    print_info "[dry-run]   1) Use the included 800x600 preset"
    print_info "[dry-run]   2) Start blank and calibrate everything myself"
    return 0
  fi

  if test -d "$RC_DIR"; then
    print_ok "runtime_config/ already exists."
    print_info ""
    print_info "What would you like to do?"
    printf '         1) Keep my existing config as-is\n'
    printf '         2) Back it up and start fresh\n'
    printf '         3) Only fill in missing files (keep existing ones)\n'
    printf '         Choice [1/2/3]: '
    local choice
    read -r choice
    choice="${choice:-1}"
    case "$choice" in
      2)
        _backup_runtime_config
        mkdir -p "$RC_DIR"
        _apply_config_choice
        ;;
      3)
        _apply_config_choice_missing_only
        ;;
      *)
        print_info "Keeping existing config."
        ;;
    esac
  else
    mkdir -p "$RC_DIR"
    _apply_config_choice
  fi
}

_backup_runtime_config() {
  local ts
  ts="$(date +%Y%m%d-%H%M%S)"
  local backup_name="runtime_config.backup.$ts"
  mv "$RC_DIR" "$project_root/$backup_name"
  print_ok "Backed up to: $backup_name"
}

_apply_config_choice() {
  print_header "Step 6 — Choose a starting config"

  printf '\n'
  printf '         Which starting config do you want?\n\n'
  printf '         1) Use the included 800x600 preset\n'
  printf '            Pre-filled coordinates from a working 800x600 Gamescope setup.\n'
  printf '            Only works if your Gamescope window is 800x600 and your\n'
  printf '            Roblox UI layout matches. If clicks land in the wrong place,\n'
  printf '            you will need to recalibrate.\n'
  printf '\n'
  printf '         2) Start blank and calibrate everything myself\n'
  printf '            Safer if your screen size or window size is different.\n'
  printf '            You fill in every coordinate yourself using xdotool.\n'
  printf '\n'
  printf '         Choice [1/2]: '
  local choice
  read -r choice
  choice="${choice:-2}"
  case "$choice" in
    1) apply_preset_800x600 ;;
    2) _apply_blank_config ;;
    *) print_warn "Unknown choice. Using blank config."; _apply_blank_config ;;
  esac
}

_apply_config_choice_missing_only() {
  print_info "Filling in missing config files only (existing files will not be changed)."
  print_info ""
  local preset_dir="$project_root/presets/800x600_known_good"
  local template_dir="$project_root/config_templates"
  local src_dir

  printf '         Which config to use for new files?\n'
  printf '         1) Use the included 800x600 preset for missing files\n'
  printf '         2) Use blank templates for missing files\n'
  printf '         Choice [1/2]: '
  local choice
  read -r choice
  choice="${choice:-2}"
  case "$choice" in
    1) src_dir="$preset_dir" ;;
    2) src_dir="$template_dir" ;;
    *) src_dir="$template_dir" ;;
  esac

  if ! test -d "$src_dir"; then
    print_warn "Source dir not found: $src_dir. Using templates."
    src_dir="$template_dir"
  fi

  local rel_file abs_src abs_dst dst_dir
  while IFS= read -r -d '' abs_src; do
    rel_file="${abs_src#$src_dir/}"
    abs_dst="$RC_DIR/$rel_file"
    if ! test -f "$abs_dst"; then
      dst_dir="${abs_dst%/*}"
      mkdir -p "$dst_dir"
      cp "$abs_src" "$abs_dst"
      print_info "Added: $rel_file"
    fi
  done < <(find "$src_dir" -type f -print0)

  print_ok "Missing files filled in."
}

apply_preset_800x600() {
  local preset_dir="$project_root/presets/800x600_known_good"

  if ! test -d "$preset_dir"; then
    print_warn "Preset directory not found: presets/800x600_known_good/"
    print_info "Falling back to blank config."
    _apply_blank_config
    return 0
  fi

  print_info "Copying 800x600 preset files into runtime_config/ ..."
  local rel_file abs_src abs_dst dst_dir
  while IFS= read -r -d '' abs_src; do
    rel_file="${abs_src#$preset_dir/}"
    abs_dst="$RC_DIR/$rel_file"
    dst_dir="${abs_dst%/*}"
    mkdir -p "$dst_dir"
    cp "$abs_src" "$abs_dst"
  done < <(find "$preset_dir" -type f -print0)

  print_ok "800x600 preset applied to runtime_config/."
  print_info ""
  print_info "IMPORTANT: These coordinates were calibrated at 800x600 Gamescope resolution."
  print_info "Start Gamescope with: gamescope -W 800 -H 600 -r 60 ..."
  print_info "If clicks land in the wrong place, you must recalibrate."
  print_info "See docs/CALIBRATION.md for how to recalibrate."
  print_info ""
  print_info "Recovery is OFF by default. Enable it only after setting your"
  print_info "private server URL and calibrating recovery button locations."
}

_apply_blank_config() {
  local template_dir="$project_root/config_templates"

  if ! test -d "$template_dir"; then
    print_warn "config_templates/ not found — cannot create blank config."
    return 1
  fi

  print_info "Copying blank templates into runtime_config/ ..."
  local rel_file abs_src abs_dst dst_dir
  while IFS= read -r -d '' abs_src; do
    rel_file="${abs_src#$template_dir/}"
    abs_dst="$RC_DIR/$rel_file"
    dst_dir="${abs_dst%/*}"
    mkdir -p "$dst_dir"
    cp "$abs_src" "$abs_dst"
  done < <(find "$template_dir" -type f -print0)

  print_ok "Blank config applied."
  print_info ""
  print_info "You must now open each file in runtime_config/ and fill in"
  print_info "your screen coordinates before running the macro."
  print_info "See docs/CALIBRATION.md for step-by-step instructions."
}

# ── Profile selection ─────────────────────────────────────────────────────────

choose_setup_profile() {
  print_header "Step 2 — Choose your setup profile"

  printf '\n'
  printf '         Which setup profile do you want?\n\n'
  printf '         1) Known-good 800x600 Sober/Gamescope  %s(recommended)%s\n' "$(printf '\033[90m')" "$(printf '\033[0m')"
  printf '            Pre-configured for a working 800x600 Gamescope+Sober setup.\n'
  printf '            Includes calibrated pack opener coordinates.\n'
  printf '            Safe startup state:\n'
  printf '              Pack Opener:      ENABLED\n'
  printf '              Market Buyer:     DISABLED  (enable after calibration)\n'
  printf '              Figurines Buyer:  DISABLED  (enable after calibration)\n'
  printf '              Recovery:         DISABLED  (enable after setting private URL)\n'
  printf '              Event Voter:      DISABLED  (enable after adding training images)\n'
  printf '\n'
  printf '         2) Custom / manual configuration\n'
  printf '            Start blank and calibrate everything yourself.\n'
  printf '            Choose this if your screen size or window size differs.\n'
  printf '\n'
  printf '         Choice [1/2]: '
  local choice
  read -r choice
  choice="${choice:-1}"
  case "$choice" in
    1)
      PROFILE_SELECTED="known_good_800x600"
      print_ok "Profile: Known-good 800x600 Sober/Gamescope"
      ;;
    2)
      PROFILE_SELECTED="custom"
      print_ok "Profile: Custom / manual"
      ;;
    *)
      print_warn "Unknown choice. Using known-good 800x600."
      PROFILE_SELECTED="known_good_800x600"
      ;;
  esac
}

# ── Known-good profile runtime config setup ───────────────────────────────────

setup_runtime_config_known_good() {
  print_header "Step 6 — Apply known-good 800x600 config"

  print_info "Copying the known-good 800x600 preset to runtime_config/."
  print_info "This sets up all configs with safe, pre-calibrated values."
  print_info ""

  if test "$DRY_RUN" = "1"; then
    if test -d "$RC_DIR"; then
      print_info "[dry-run] runtime_config/ already exists."
      print_info "[dry-run] Would back it up with a timestamp, then replace it."
    else
      print_info "[dry-run] Would create runtime_config/ and apply 800x600 preset."
    fi
    return 0
  fi

  if test -d "$RC_DIR"; then
    local ts
    ts="$(date +%Y%m%d-%H%M%S)"
    local backup_name="runtime_config.backup.$ts"
    print_info "Existing runtime_config/ found — backing up to: $backup_name"
    mv "$RC_DIR" "$project_root/$backup_name"
    print_ok "Backed up: $backup_name"
  fi

  mkdir -p "$RC_DIR"
  apply_preset_800x600
}

# ── Launcher installation ─────────────────────────────────────────────────────

install_acc_launcher() {
  print_header "Step 9 — Install the acc terminal command"

  printf '         This installs ~/.local/bin/acc so you can type "acc" from any\n'
  printf '         terminal. The launcher sets required env vars and cds to the repo.\n'
  printf '\n'

  local launcher_dir="$HOME/.local/bin"
  local launcher_path="$launcher_dir/acc"

  if test "$DRY_RUN" = "1"; then
    print_info "[dry-run] Would install: $launcher_path"
    print_info "[dry-run] Content:"
    print_info "  #!/usr/bin/env bash"
    print_info "  cd $project_root"
    print_info "  export MACRO_INPUT_MODE=live"
    print_info "  export MACRO_LIVE_INPUT_ALLOWED=1"
    print_info "  export MACRO_LIVE_CYCLE_RUNNER_CONFIRM=YES"
    print_info "  exec ./bin/acc \"\$@\""
    return 0
  fi

  # Detect and refuse a recursive wrapper (launcher pointing to itself).
  if test -f "$launcher_path"; then
    if grep -qF "$launcher_path" "$launcher_path" 2>/dev/null; then
      print_warn "Found recursive launcher (points to itself) — replacing."
      rm -f "$launcher_path"
    else
      print_info "Replacing existing launcher."
    fi
  fi

  mkdir -p "$launcher_dir"

  cat > "$launcher_path" << LAUNCHER_EOF
#!/usr/bin/env bash
# ACC launcher — installed by setup-acc
# Repo: $project_root
cd "$project_root" || { printf 'ERROR: Cannot cd to %s\n' "$project_root" >&2; exit 1; }
export MACRO_INPUT_MODE=live
export MACRO_LIVE_INPUT_ALLOWED=1
export MACRO_LIVE_CYCLE_RUNNER_CONFIRM=YES
exec ./bin/acc "\$@"
LAUNCHER_EOF

  chmod +x "$launcher_path"
  LAUNCHER_INSTALLED=1
  print_ok "Installed: $launcher_path"

  _ensure_local_bin_in_path "$launcher_dir"
}

_ensure_local_bin_in_path() {
  local bin_dir="${1:-$HOME/.local/bin}"

  case ":$PATH:" in
    *":$bin_dir:"*)
      print_ok "$bin_dir is already in PATH"
      return 0
      ;;
  esac

  print_warn "$bin_dir is not in your current PATH."
  print_info "Adding it to ~/.bashrc and ~/.zshrc so it is available in new terminals."
  print_info ""

  local profile_line='export PATH="$HOME/.local/bin:$PATH"'
  local added_count=0

  for rcfile in "$HOME/.bashrc" "$HOME/.zshrc"; do
    if test -f "$rcfile"; then
      if ! grep -q '.local/bin' "$rcfile" 2>/dev/null; then
        printf '\n# Added by ACC setup-acc\n%s\n' "$profile_line" >> "$rcfile"
        print_ok "Added ~/.local/bin to PATH in: $rcfile"
        added_count=$((added_count + 1))
      else
        print_info "~/.local/bin already referenced in: $rcfile"
      fi
    fi
  done

  if test "$added_count" -eq 0; then
    print_warn "Could not auto-add PATH. Add this line to your shell profile:"
    print_info "  $profile_line"
  fi
}

# ── Final summary ─────────────────────────────────────────────────────────────

show_final_summary() {
  print_header "Setup complete — Summary"

  printf '  Repo:    %s\n' "$project_root"
  printf '  Profile: %s\n' "${PROFILE_SELECTED:-not selected}"
  printf '\n'

  print_header "  Dependencies"
  for cmd in gamescope xdotool flatpak python3; do
    if command_exists "$cmd"; then
      print_ok "$cmd"
    else
      print_miss "$cmd"
    fi
  done
  if test "$SOBER_INSTALLED" = "1"; then
    print_ok "Sober (org.vinegarhq.Sober)"
  else
    print_warn "Sober — not installed"
  fi
  if test "$OPENCV_AVAILABLE" = "1"; then
    print_ok "python3-opencv (Event Voter ready)"
  else
    print_warn "python3-opencv — not installed (Event Voter disabled)"
  fi

  print_header "  Config (runtime_config/)"
  if test -d "$RC_DIR"; then
    print_ok "runtime_config/ — exists"
    _report_config_status
  else
    print_miss "runtime_config/ — not found"
  fi

  print_header "  Module toggles"
  _report_toggle_status_from_config

  print_header "  Event Voter"
  local ev_training="$RC_DIR/event_voter/training"
  if test -f "$ev_training/live_event_seed.png" && \
     test -f "$ev_training/live_event_seed_mutation.png"; then
    print_ok "Training images present"
  else
    print_warn "Training images not yet added"
    print_info "See docs/EVENT_VOTER_EXPERIMENT.md"
  fi

  print_header "  acc command"
  local launcher_path="$HOME/.local/bin/acc"
  if test -f "$launcher_path"; then
    print_ok "Installed: $launcher_path"
  else
    print_miss "Not installed (run setup again, or use ./bin/acc)"
  fi

  print_header "What to do next"
  printf '\n'
  printf '  1. Start Gamescope with Sober:\n'
  printf '\n'
  printf '       gamescope -W 800 -H 600 -r 60 --force-grab-cursor -- \\\n'
  printf '         flatpak run org.vinegarhq.Sober\n'
  printf '\n'
  printf '  2. Run the ACC menu:\n'

  if test -f "$HOME/.local/bin/acc"; then
    case ":$PATH:" in
      *":$HOME/.local/bin:"*)
        printf '\n       Run: acc\n\n'
        ;;
      *)
        printf '\n       Close this terminal, open a new terminal, run: acc\n\n'
        ;;
    esac
  else
    printf '\n       cd %s && ./bin/acc\n\n' "$project_root"
  fi

  printf '  3. Inside ACC: check module status (option 5), then start\n'
  printf '     pack opener only (option 2). Watch a few cycles.\n'
  printf '     Enable Market/Figurines Buyer only after calibration.\n'
  printf '\n'
  printf '  If setup fails, run the diagnostic tool:\n'
  printf '    ./bin/setup-acc --diagnose\n'
  printf '  Then send the file: ~/acc_setup_diagnose.txt\n'
  printf '\n'
}

_report_toggle_status_from_config() {
  local toggles_file="$RC_DIR/ui/toggles.conf"
  local pack_t=1 market_t=0 figurines_t=0 recovery_t=0 ev_t=0

  if test -f "$toggles_file"; then
    local k v
    while IFS='=' read -r k v; do
      case "$k" in
        '#'*|'') continue ;;
        TOGGLE_PACK_OPENER)      pack_t="$v" ;;
        TOGGLE_MARKET_BUYER)     market_t="$v" ;;
        TOGGLE_FIGURINES_BUYER)  figurines_t="$v" ;;
        TOGGLE_RECOVERY_RESTART) recovery_t="$v" ;;
        TOGGLE_EVENT_VOTER)      ev_t="$v" ;;
      esac
    done < "$toggles_file" 2>/dev/null || true
  else
    local orch_defs="$RC_DIR/orchestrator/defaults.conf"
    if test -f "$orch_defs"; then
      local k v
      while IFS='=' read -r k v; do
        case "$k" in
          '#'*|'') continue ;;
          PACK_OPENER_ENABLED)     pack_t="$v" ;;
          MARKET_BUYER_ENABLED)    market_t="$v" ;;
          FIGURINES_BUYER_ENABLED) figurines_t="$v" ;;
        esac
      done < "$orch_defs" 2>/dev/null || true
    fi
    local rec_defs="$RC_DIR/recovery/defaults.conf"
    if test -f "$rec_defs"; then
      recovery_t="$(grep '^RECOVERY_ENABLED=' "$rec_defs" | tail -n1 | cut -d= -f2- || true)"
    fi
    local ev_defs="$RC_DIR/event_voter/defaults.conf"
    if test -f "$ev_defs"; then
      ev_t="$(grep '^EVENT_VOTER_ENABLED=' "$ev_defs" | tail -n1 | cut -d= -f2- || true)"
    fi
  fi

  if test "${pack_t:-1}" = "1"; then
    print_ok "Pack Opener — ENABLED"
  else
    print_warn "Pack Opener — DISABLED"
  fi
  if test "${market_t:-0}" = "1"; then
    print_ok "Market Buyer — ENABLED"
  else
    print_warn "Market Buyer — DISABLED (enable after calibration in ACC menu → Module toggles)"
  fi
  if test "${figurines_t:-0}" = "1"; then
    print_ok "Figurines Buyer — ENABLED"
  else
    print_warn "Figurines Buyer — DISABLED (enable after calibration)"
  fi
  if test "${recovery_t:-0}" = "1"; then
    print_ok "Recovery Restart — ENABLED"
  else
    print_warn "Recovery Restart — DISABLED (enable after setting private server URL)"
  fi
  if test "${ev_t:-0}" = "1"; then
    print_ok "Event Voter — ENABLED"
  else
    print_warn "Event Voter — DISABLED (enable after adding training images)"
  fi
}

# ── Diagnose command ──────────────────────────────────────────────────────────

run_diagnose() {
  local out_file="$HOME/acc_setup_diagnose.txt"
  printf 'Writing diagnostic file: %s\n' "$out_file"
  printf '\n'

  {
    printf '# ACC Setup Diagnostics\n'
    printf 'date: %s\n' "$(date)"
    printf 'repo: %s\n' "$project_root"
    printf 'git_commit: %s\n' "$(git -C "$project_root" log -1 --oneline 2>/dev/null || printf '<none>')"
    printf '\n=== git status ===\n'
    git -C "$project_root" status --short 2>/dev/null || printf '<error>\n'

    printf '\n=== ~/.local/bin/acc ===\n'
    local launcher_path="$HOME/.local/bin/acc"
    if test -f "$launcher_path"; then
      cat "$launcher_path"
    else
      printf '<not installed>\n'
    fi

    printf '\n=== bin/acc (first 15 lines) ===\n'
    head -n15 "$project_root/bin/acc" 2>/dev/null || printf '<not found>\n'

    printf '\n=== runtime_config/orchestrator/defaults.conf ===\n'
    local orch_conf="$project_root/runtime_config/orchestrator/defaults.conf"
    if test -f "$orch_conf"; then cat "$orch_conf"; else printf '<not found>\n'; fi

    printf '\n=== runtime_config/ui/toggles.conf ===\n'
    local ui_conf="$project_root/runtime_config/ui/toggles.conf"
    if test -f "$ui_conf"; then cat "$ui_conf"; else printf '<not found>\n'; fi

    printf '\n=== pack_opener/points.conf ===\n'
    local po_pts="$project_root/runtime_config/pack_opener/points.conf"
    if test -f "$po_pts"; then cat "$po_pts"; else printf '<not found>\n'; fi

    printf '\n=== pack_opener/timing.conf ===\n'
    local po_timing="$project_root/runtime_config/pack_opener/timing.conf"
    if test -f "$po_timing"; then cat "$po_timing"; else printf '<not found>\n'; fi

    printf '\n=== pack_opener/potion_plan.conf ===\n'
    local po_plan="$project_root/runtime_config/pack_opener/potion_plan.conf"
    if test -f "$po_plan"; then cat "$po_plan"; else printf '<not found>\n'; fi

    printf '\n=== runtime_config/event_voter/defaults.conf ===\n'
    local ev_conf="$project_root/runtime_config/event_voter/defaults.conf"
    if test -f "$ev_conf"; then cat "$ev_conf"; else printf '<not found>\n'; fi

    printf '\n=== Dependencies ===\n'
    for cmd in bash git python3 xdotool flatpak gamescope grep sed; do
      printf '%s: %s\n' "$cmd" "$(command -v "$cmd" 2>/dev/null || printf '<not found>')"
    done

    printf '\n=== Sober (flatpak) ===\n'
    if command_exists flatpak; then
      flatpak list 2>/dev/null | grep -i sober || printf '<not installed>\n'
    else
      printf '<flatpak not found>\n'
    fi

    printf '\n=== Running processes ===\n'
    pgrep -la gamescope 2>/dev/null || printf 'gamescope: <none>\n'
    pgrep -la sober 2>/dev/null || printf 'sober: <none>\n'

    printf '\n=== Display environment ===\n'
    printf 'DISPLAY=%s\n' "${DISPLAY:-<not set>}"
    printf 'WAYLAND_DISPLAY=%s\n' "${WAYLAND_DISPLAY:-<not set>}"

    printf '\n=== xdotool DISPLAY=:1 getmouselocation ===\n'
    if command_exists xdotool; then
      DISPLAY=:1 xdotool getmouselocation --shell 2>/dev/null || \
        printf '<failed — Gamescope may not be running or DISPLAY=:1 is wrong>\n'
    else
      printf '<xdotool not found>\n'
    fi

    printf '\n=== dry-run live-cycle (1 cycle) ===\n'
    MACRO_INPUT_MODE=dry-run MACRO_PROJECT_ROOT="$project_root" \
      "$project_root/bin/macroctl" dry-run live-cycle --cycles 1 2>&1 \
      | head -n60 || printf '<error running dry-run>\n'

    printf '\n=== OpenCV (python3-opencv) ===\n'
    python3 -c "import cv2; print('cv2 version:', cv2.__version__)" 2>/dev/null || \
      printf '<python3-opencv not available>\n'

    printf '\n=== Event Voter training files ===\n'
    local ev_train="$project_root/runtime_config/event_voter/training"
    if test -d "$ev_train"; then
      ls -la "$ev_train" 2>/dev/null || printf '<empty>\n'
    else
      printf '<directory not found: %s>\n' "$ev_train"
    fi

    printf '\n=== Latest ACC logs ===\n'
    local log_dir="$project_root/05_debug_snapshots/logs"
    if test -d "$log_dir"; then
      local found_logs=0
      while IFS= read -r f; do
        found_logs=1
        printf '\n--- %s ---\n' "$f"
        tail -n20 "$f" 2>/dev/null || true
      done < <(
        find "$log_dir" -maxdepth 1 -type f -printf '%T@ %p\n' 2>/dev/null \
          | sort -rn | head -n3 | sed 's/^[^ ]* //'
      )
      if test "$found_logs" = "0"; then
        printf '<no log files found>\n'
      fi
    else
      printf '<no log directory>\n'
    fi

  } > "$out_file" 2>&1

  printf 'Send this file for debugging: %s\n' "$out_file"
}

# ── Private server URL ────────────────────────────────────────────────────────

setup_private_server_url() {
  print_header "Step 7 — Optional: Private server URL"

  print_info "If you want ACC to automatically rejoin a private server (via Recovery"
  print_info "Restart or Sober Instance Launcher), you can save your URL now."
  print_info ""
  print_info "You can skip this step and add it later by editing:"
  print_info "  runtime_config/recovery/defaults.conf"
  print_info "  runtime_config/sober_launcher/defaults.conf"
  print_info ""
  print_info "NEVER commit runtime_config/ — it stays local and is gitignored."
  print_info ""

  if test "$DRY_RUN" = "1"; then
    print_info "[dry-run] Would ask whether to set a private server URL."
    print_info "[dry-run] If yes, would write it to:"
    print_info "[dry-run]   runtime_config/recovery/defaults.conf"
    print_info "[dry-run]   runtime_config/sober_launcher/defaults.conf"
    print_info "[dry-run] The URL would never be printed again after storing."
    return 0
  fi

  if ! ask_yes_no "Set a private server URL now?" "n"; then
    print_info "Skipped. Add it later in runtime_config/recovery/defaults.conf if needed."
    return 0
  fi

  local url
  printf '         Paste your private server URL (will not be shown again): '
  read -r url

  if test -z "$url"; then
    print_warn "No URL entered. Skipping."
    return 0
  fi

  # Write to recovery config
  local rec_dir="$RC_DIR/recovery"
  local rec_defaults="$rec_dir/defaults.conf"
  mkdir -p "$rec_dir"

  if test -f "$rec_defaults"; then
    local tmp_file
    tmp_file="$(mktemp)"
    grep -v '^RECOVERY_PRIVATE_SERVER_URL=' "$rec_defaults" > "$tmp_file" || true
    printf "RECOVERY_PRIVATE_SERVER_URL='%s'\n" "$url" >> "$tmp_file"
    mv "$tmp_file" "$rec_defaults"
  else
    if test -f "$project_root/config_templates/recovery/defaults.conf"; then
      cp "$project_root/config_templates/recovery/defaults.conf" "$rec_defaults"
    fi
    printf "RECOVERY_PRIVATE_SERVER_URL='%s'\n" "$url" >> "$rec_defaults"
  fi

  print_ok "Configured: runtime_config/recovery/defaults.conf"

  # Write to sober_launcher config
  local sl_dir="$RC_DIR/sober_launcher"
  local sl_defaults="$sl_dir/defaults.conf"
  mkdir -p "$sl_dir"

  if test -f "$sl_defaults"; then
    local tmp_file2
    tmp_file2="$(mktemp)"
    grep -v '^SOBER_PRIVATE_SERVER_URL=' "$sl_defaults" > "$tmp_file2" || true
    printf "SOBER_PRIVATE_SERVER_URL='%s'\n" "$url" >> "$tmp_file2"
    mv "$tmp_file2" "$sl_defaults"
  else
    if test -f "$project_root/config_templates/sober_launcher/defaults.conf"; then
      cp "$project_root/config_templates/sober_launcher/defaults.conf" "$sl_defaults"
    fi
    printf "SOBER_PRIVATE_SERVER_URL='%s'\n" "$url" >> "$sl_defaults"
  fi

  print_ok "Configured: runtime_config/sober_launcher/defaults.conf"
  print_info ""
  print_info "Recovery and Sober Launcher are still OFF by default."
  print_info "Enable them only after calibrating their button locations."
  print_info "See docs/CALIBRATION.md for the full point list."
}

# ── Event Voter training image info ──────────────────────────────────────────

setup_event_voter_info() {
  print_header "Event Voter — Setup and validation"

  print_info "Event Voter is an experimental visual module that auto-votes in"
  print_info "Roblox in-game events. It is DISABLED by default."
  print_info ""
  print_info "Requirements:"
  print_info "  - python3-opencv must be installed"
  print_info "  - Two training screenshots must be placed in:"
  print_info "      runtime_config/event_voter/training/live_event_seed.png"
  print_info "      runtime_config/event_voter/training/live_event_seed_mutation.png"
  print_info "  See docs/EVENT_VOTER_EXPERIMENT.md for how to capture them."
  print_info ""

  local training_dir="$RC_DIR/event_voter/training"
  local ev_defaults="$RC_DIR/event_voter/defaults.conf"

  if test "$DRY_RUN" = "1"; then
    print_info "[dry-run] Would create: runtime_config/event_voter/training/"
    print_info "[dry-run] Would check for training images and auto-disable if missing."
    return 0
  fi

  mkdir -p "$training_dir"

  # Check training files
  local has_seed=0 has_mutation=0
  if test -f "$training_dir/live_event_seed.png"; then has_seed=1; fi
  if test -f "$training_dir/live_event_seed_mutation.png"; then has_mutation=1; fi

  if test "$has_seed" = "1" && test "$has_mutation" = "1"; then
    print_ok "Event Voter training images — present"
  else
    print_warn "Event Voter training images — not yet added"
    if test "$has_seed" = "0"; then
      print_miss "Missing: runtime_config/event_voter/training/live_event_seed.png"
    fi
    if test "$has_mutation" = "0"; then
      print_miss "Missing: runtime_config/event_voter/training/live_event_seed_mutation.png"
    fi
    print_info ""
    print_info "Event Voter remains DISABLED until training images are added."
    print_info "See docs/EVENT_VOTER_EXPERIMENT.md for capture instructions."
  fi

  # Auto-disable Event Voter if it's enabled but missing requirements.
  if test -f "$ev_defaults"; then
    local ev_enabled
    ev_enabled="$(grep '^EVENT_VOTER_ENABLED=' "$ev_defaults" | tail -n1 | cut -d= -f2- || true)"
    if test "${ev_enabled:-0}" = "1"; then
      local needs_disable=0
      if test "$OPENCV_AVAILABLE" != "1"; then needs_disable=1; fi
      if test "$has_seed" = "0" || test "$has_mutation" = "0"; then needs_disable=1; fi
      if test "$needs_disable" = "1"; then
        local tmp_ev
        tmp_ev="$(mktemp)"
        grep -v '^EVENT_VOTER_ENABLED=' "$ev_defaults" \
          | grep -v '^EVENT_VOTER_LIVE_ALLOWED=' > "$tmp_ev" || true
        printf 'EVENT_VOTER_ENABLED=0\n' >> "$tmp_ev"
        printf 'EVENT_VOTER_LIVE_ALLOWED=0\n' >> "$tmp_ev"
        mv "$tmp_ev" "$ev_defaults"
        print_warn "Event Voter was ENABLED but missing requirements — auto-disabled."
        if test "$OPENCV_AVAILABLE" != "1"; then
          print_info "  Missing: python3-opencv"
          print_info "  Install: sudo apt install python3-opencv  (Pop!/Ubuntu)"
          print_info "           sudo dnf install python3-opencv  (Fedora)"
        fi
        if test "$has_seed" = "0" || test "$has_mutation" = "0"; then
          print_info "  Missing: training images (see above)"
        fi
        print_info "  Re-enable: edit runtime_config/event_voter/defaults.conf"
        print_info "             or use ACC menu → Module toggles → Event Voter"
      fi
    fi
  fi

  print_ok "runtime_config/event_voter/training/ — ready (add your screenshots here)"
}

# ── Validation ────────────────────────────────────────────────────────────────

run_validation() {
  print_header "Step 9 — Non-live validation checks"

  print_info "Running syntax and config checks only. No live input will be sent."
  print_info ""

  local failed=0

  # Syntax check
  printf '  Checking script syntax (bash -n) ...\n'
  local syntax_ok=1
  bash -n \
    "$project_root/bin/acc" \
    "$project_root/bin/pack-opener-ui" \
    "$project_root/bin/macroctl" \
    "$project_root/bin/setup-acc" \
    2>&1 | sed 's/^/    /' || syntax_ok=0

  local module_sh lib_sh
  for module_sh in "$project_root/src/modules/"*.sh; do
    test -f "$module_sh" && bash -n "$module_sh" 2>&1 | sed 's/^/    /' || syntax_ok=0
  done
  for lib_sh in "$project_root/src/lib/"*.sh; do
    test -f "$lib_sh" && bash -n "$lib_sh" 2>&1 | sed 's/^/    /' || syntax_ok=0
  done

  if test "$syntax_ok" = "1"; then
    print_ok "Syntax check passed"
  else
    print_warn "Syntax check found issues (see above)"
    failed=1
  fi

  # Status check
  printf '\n  Running: macroctl status\n'
  if MACRO_PROJECT_ROOT="$project_root" "$project_root/bin/macroctl" status 2>&1 | sed 's/^/    /'; then
    print_ok "macroctl status"
  else
    print_warn "macroctl status returned non-zero (expected if Gamescope is not running)"
    failed=1
  fi

  # Validate config
  printf '\n  Running: macroctl validate-config pack-opener\n'
  if MACRO_PROJECT_ROOT="$project_root" "$project_root/bin/macroctl" validate-config pack-opener 2>&1 | sed 's/^/    /'; then
    print_ok "validate-config pack-opener"
  else
    print_warn "validate-config pack-opener found issues (calibrate coordinates if using blank config)"
    failed=1
  fi

  printf '\n  Running: macroctl validate-config orchestrator\n'
  if MACRO_PROJECT_ROOT="$project_root" "$project_root/bin/macroctl" validate-config orchestrator 2>&1 | sed 's/^/    /'; then
    print_ok "validate-config orchestrator"
  else
    print_warn "validate-config orchestrator found issues"
    failed=1
  fi

  printf '\n  Running: macroctl validate-config recovery\n'
  if MACRO_PROJECT_ROOT="$project_root" "$project_root/bin/macroctl" validate-config recovery 2>&1 | sed 's/^/    /'; then
    print_ok "validate-config recovery"
  else
    print_warn "validate-config recovery found issues"
    failed=1
  fi

  printf '\n  Running: macroctl validate-config sober-launcher\n'
  if MACRO_PROJECT_ROOT="$project_root" "$project_root/bin/macroctl" validate-config sober-launcher 2>&1 | sed 's/^/    /'; then
    print_ok "validate-config sober-launcher"
  else
    print_warn "validate-config sober-launcher found issues"
    failed=1
  fi

  printf '\n  Running: macroctl validate-config event-voter\n'
  if MACRO_PROJECT_ROOT="$project_root" "$project_root/bin/macroctl" validate-config event-voter 2>&1 | sed 's/^/    /'; then
    print_ok "validate-config event-voter"
  else
    print_warn "validate-config event-voter found issues (expected if opencv not installed)"
  fi

  printf '\n  Running: macroctl dry-run orchestrator --cycles 3\n'
  if MACRO_INPUT_MODE=dry-run MACRO_PROJECT_ROOT="$project_root" \
      "$project_root/bin/macroctl" dry-run orchestrator --cycles 3 2>&1 | sed 's/^/    /'; then
    print_ok "dry-run orchestrator"
  else
    print_warn "dry-run orchestrator returned issues"
    failed=1
  fi

  printf '\n  Running: macroctl dry-run recovery\n'
  if MACRO_INPUT_MODE=dry-run MACRO_PROJECT_ROOT="$project_root" \
      "$project_root/bin/macroctl" dry-run recovery 2>&1 | sed 's/^/    /'; then
    print_ok "dry-run recovery"
  else
    print_warn "dry-run recovery returned issues (expected if recovery is not yet configured)"
  fi

  printf '\n  Running: macroctl dry-run sober-launcher-status\n'
  if MACRO_INPUT_MODE=dry-run MACRO_PROJECT_ROOT="$project_root" \
      "$project_root/bin/macroctl" dry-run sober-launcher-status 2>&1 | sed 's/^/    /'; then
    print_ok "dry-run sober-launcher-status"
  else
    print_warn "dry-run sober-launcher-status returned issues"
  fi

  printf '\n  Running: macroctl dry-run sober-launcher-open-private\n'
  if MACRO_INPUT_MODE=dry-run MACRO_PROJECT_ROOT="$project_root" \
      "$project_root/bin/macroctl" dry-run sober-launcher-open-private 2>&1 | sed 's/^/    /'; then
    print_ok "dry-run sober-launcher-open-private"
  else
    print_warn "dry-run sober-launcher-open-private returned issues (expected if no URL configured)"
  fi

  printf '\n  Running: macroctl dry-run event-voter-schedule\n'
  if MACRO_INPUT_MODE=dry-run MACRO_PROJECT_ROOT="$project_root" \
      "$project_root/bin/macroctl" dry-run event-voter-schedule 2>&1 | sed 's/^/    /'; then
    print_ok "dry-run event-voter-schedule"
  else
    print_warn "dry-run event-voter-schedule returned issues (expected if event voter is disabled)"
  fi

  printf '\n'
  if test "$failed" = "0"; then
    print_ok "All non-live checks passed."
  else
    print_warn "Some checks had warnings — see output above."
    print_info "Warnings are expected when runtime_config/ is not yet calibrated."
    print_info "The macro will not work correctly until all coordinates are filled in."
  fi
}

# ── Status check (--check mode) ───────────────────────────────────────────────

show_status() {
  print_header "ACC System and Config Status"

  printf '  OS:  %s\n' "$OS_PRETTY"
  if test "$IS_UBUNTU_LIKE" = "1"; then
    print_ok "Pop!_OS / Ubuntu-based — supported"
  else
    print_warn "Not Pop!_OS / Ubuntu-based — may need manual setup"
  fi

  printf '\n  Package manager:\n'
  if test "$HAS_APT" = "1"; then
    print_ok "apt — Available (automatic install supported)"
  else
    print_warn "apt — Not found (manual install required)"
  fi

  print_header "Programs"
  check_dependencies

  print_header "Sober (Roblox client)"
  if command_exists flatpak; then
    check_sober
    if test "$IS_UBUNTU_LIKE" = "1" && test "$SOBER_INSTALLED" = "0"; then
      print_info "Install with: flatpak install flathub org.vinegarhq.Sober"
    fi
  else
    print_miss "flatpak — Not installed (required to check or install Sober)"
  fi

  print_header "Local config (runtime_config/)"
  if test -d "$RC_DIR"; then
    print_ok "runtime_config/ — Exists"
    _report_config_status
  else
    print_miss "runtime_config/ — Not found"
    print_info "Run ./bin/setup-acc to create it."
  fi
  printf '\n'
}

_report_config_status() {
  local po_pts="$RC_DIR/pack_opener/points.conf"
  if test -f "$po_pts"; then
    local blank filled
    blank="$(grep -cE '=$' "$po_pts" || true)"
    filled="$(grep -cE '=[^[:space:]]' "$po_pts" || true)"
    if test "${filled:-0}" -eq 0; then
      print_warn "pack_opener/points.conf — Needs calibration (all points blank)"
    elif test "${blank:-0}" -gt 0; then
      print_warn "pack_opener/points.conf — Partially calibrated ($filled filled, $blank blank)"
    else
      print_ok "pack_opener/points.conf — Configured ($filled points)"
    fi
  else
    print_miss "pack_opener/points.conf — Not found"
  fi

  local rec_def="$RC_DIR/recovery/defaults.conf"
  if test -f "$rec_def"; then
    local rec_url
    rec_url="$(grep -E '^RECOVERY_PRIVATE_SERVER_URL=' "$rec_def" | tail -n1 | cut -d= -f2- || true)"
    rec_url="${rec_url#\'}"
    rec_url="${rec_url%\'}"
    if test -n "$rec_url"; then
      print_ok "recovery/defaults.conf — Private server URL: Configured"
    else
      print_warn "recovery/defaults.conf — Private server URL: Not configured (recovery will not work)"
    fi
  else
    print_miss "recovery/defaults.conf — Not found"
  fi
}


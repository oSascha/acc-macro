#!/usr/bin/env bash
set -euo pipefail

# ACC Setup Wizard — guides new Pop!_OS users through installing dependencies,
# creating local config, and running non-live validation.

# ── Path resolution ───────────────────────────────────────────────────────────

setup_script="${BASH_SOURCE[0]}"
setup_bin_dir="$(cd "${setup_script%/*}" && pwd -P)"
project_root="${setup_bin_dir%/bin}"

# ── Global state ──────────────────────────────────────────────────────────────

DRY_RUN=0
CHECK_ONLY=0

OS_PRETTY="Unknown"
IS_UBUNTU_LIKE=0
HAS_APT=0

DEPS_MISSING=()
SOBER_INSTALLED=0

RC_DIR="$project_root/runtime_config"

# ── Helpers ───────────────────────────────────────────────────────────────────

print_header() {
  printf '\n\033[1;34m=== %s ===\033[0m\n\n' "$1"
}

print_ok() {
  printf '  \033[1;32m[OK]\033[0m   %s\n' "$1"
}

print_warn() {
  printf '  \033[1;33m[WARN]\033[0m %s\n' "$1"
}

print_miss() {
  printf '  \033[1;31m[MISS]\033[0m %s\n' "$1"
}

print_info() {
  printf '         %s\n' "$1"
}

ask_yes_no() {
  local prompt="$1"
  local default="${2:-y}"
  local answer
  while true; do
    if test "$default" = "y"; then
      printf '%s [Y/n]: ' "$prompt"
    else
      printf '%s [y/N]: ' "$prompt"
    fi
    read -r answer
    answer="${answer:-$default}"
    case "$answer" in
      [Yy]*) return 0 ;;
      [Nn]*) return 1 ;;
      *) printf 'Please answer yes or no.\n' ;;
    esac
  done
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

# ── OS detection ──────────────────────────────────────────────────────────────

detect_os() {
  if test -f /etc/os-release; then
    local os_id id_like
    os_id="$(. /etc/os-release && printf '%s' "${ID:-unknown}")"
    id_like="$(. /etc/os-release && printf '%s' "${ID_LIKE:-}")"
    OS_PRETTY="$(. /etc/os-release && printf '%s' "${PRETTY_NAME:-$os_id}")"
    case "$os_id" in
      pop|ubuntu|debian|linuxmint)
        IS_UBUNTU_LIKE=1
        ;;
      *)
        case "$id_like" in
          *ubuntu*|*debian*)
            IS_UBUNTU_LIKE=1
            ;;
        esac
        ;;
    esac
  fi
  if command_exists apt; then
    HAS_APT=1
  fi
}

# ── Dependency check ──────────────────────────────────────────────────────────

DEPS_REQUIRED=(bash git python3 xdotool flatpak gamescope grep sed)
DEPS_OPTIONAL=(wl-copy xdg-open gawk awk)

check_dependencies() {
  DEPS_MISSING=()
  local dep
  for dep in "${DEPS_REQUIRED[@]}"; do
    if command_exists "$dep"; then
      print_ok "$dep — Installed"
    else
      print_miss "$dep — Missing"
      DEPS_MISSING+=("$dep")
    fi
  done
  printf '\n'
  print_info "Optional programs:"
  for dep in "${DEPS_OPTIONAL[@]}"; do
    if command_exists "$dep"; then
      print_ok "$dep — Installed"
    else
      print_warn "$dep — Missing (not required, ACC falls back gracefully)"
    fi
  done
  printf '\n'
  if test "${#DEPS_MISSING[@]}" -eq 0; then
    print_ok "All required programs are installed."
  else
    print_warn "Missing required programs: ${DEPS_MISSING[*]}"
  fi
}

# ── Install missing dependencies ──────────────────────────────────────────────

install_dependencies() {
  if test "${#DEPS_MISSING[@]}" -eq 0; then
    print_info "Nothing to install — all required programs are already present."
    return 0
  fi

  print_header "Step 3 — Install missing programs"

  if test "$DRY_RUN" = "1"; then
    print_info "[dry-run] Would offer to run:"
    print_info "  sudo apt update"
    print_info "  sudo apt install -y bash coreutils git grep sed gawk python3 xdotool xdg-utils flatpak gamescope wl-clipboard"
    return 0
  fi

  if test "$HAS_APT" = "0"; then
    print_warn "apt package manager not found."
    print_info "Please install the following programs using your package manager:"
    print_info "  bash coreutils git grep sed gawk python3 xdotool xdg-utils flatpak gamescope wl-clipboard"
    return 0
  fi

  print_info "The following command will be used to install missing programs:"
  print_info ""
  print_info "  sudo apt update"
  print_info "  sudo apt install -y bash coreutils git grep sed gawk python3 xdotool xdg-utils flatpak gamescope wl-clipboard"
  print_info ""
  print_info "You may be asked for your password."
  print_info ""

  if ask_yes_no "Install missing programs now?" "y"; then
    sudo apt update
    sudo apt install -y bash coreutils git grep sed gawk python3 xdotool xdg-utils flatpak gamescope wl-clipboard
    print_ok "Install complete."
  else
    print_warn "Skipped. Install missing programs before running the macro live."
  fi
}

# ── Sober check ───────────────────────────────────────────────────────────────

check_sober() {
  if command_exists flatpak && flatpak list 2>/dev/null | grep -q "org.vinegarhq.Sober"; then
    SOBER_INSTALLED=1
    print_ok "Sober (org.vinegarhq.Sober) — Installed"
  else
    SOBER_INSTALLED=0
    print_miss "Sober (org.vinegarhq.Sober) — Not installed"
  fi
}

install_sober() {
  if test "$SOBER_INSTALLED" = "1"; then
    print_info "Sober is already installed. Nothing to do."
    return 0
  fi

  if test "$DRY_RUN" = "1"; then
    print_info "[dry-run] Would offer to run:"
    print_info "  flatpak install -y flathub org.vinegarhq.Sober"
    return 0
  fi

  print_info "Sober is the Roblox client that runs on Linux via Flatpak."
  print_info "This will run:"
  print_info "  flatpak install -y flathub org.vinegarhq.Sober"
  print_info ""

  if ask_yes_no "Install Sober now?" "y"; then
    flatpak install -y flathub org.vinegarhq.Sober
    SOBER_INSTALLED=1
    print_ok "Sober installed."
  else
    print_warn "Skipped. You must install Sober before running the macro live."
    print_info "Run manually: flatpak install flathub org.vinegarhq.Sober"
  fi
}

# ── Runtime config setup ──────────────────────────────────────────────────────

setup_runtime_config() {
  print_header "Step 5 — Set up your local config folder (runtime_config/)"

  print_info "ACC stores your personal settings in runtime_config/."
  print_info "This folder is gitignored — it stays private on your computer."
  print_info "It is never committed to git."
  print_info ""

  if test "$DRY_RUN" = "1"; then
    if test -d "$RC_DIR"; then
      print_info "[dry-run] runtime_config/ already exists."
      print_info "[dry-run] Would ask: keep, back up, or fill in missing files."
    else
      print_info "[dry-run] runtime_config/ does not exist."
      print_info "[dry-run] Would create it and ask which starting config to use."
    fi
    print_info "[dry-run] Would then ask:"
    print_info "[dry-run]   1) Use the included 800x600 preset"
    print_info "[dry-run]   2) Start blank and calibrate everything myself"
    return 0
  fi

  if test -d "$RC_DIR"; then
    print_ok "runtime_config/ already exists."
    print_info ""
    print_info "What would you like to do?"
    printf '         1) Keep my existing config as-is\n'
    printf '         2) Back it up and start fresh\n'
    printf '         3) Only fill in missing files (keep existing ones)\n'
    printf '         Choice [1/2/3]: '
    local choice
    read -r choice
    choice="${choice:-1}"
    case "$choice" in
      2)
        _backup_runtime_config
        mkdir -p "$RC_DIR"
        _apply_config_choice
        ;;
      3)
        _apply_config_choice_missing_only
        ;;
      *)
        print_info "Keeping existing config."
        ;;
    esac
  else
    mkdir -p "$RC_DIR"
    _apply_config_choice
  fi
}

_backup_runtime_config() {
  local ts
  ts="$(date +%Y%m%d-%H%M%S)"
  local backup_name="runtime_config.backup.$ts"
  mv "$RC_DIR" "$project_root/$backup_name"
  print_ok "Backed up to: $backup_name"
}

_apply_config_choice() {
  print_header "Step 6 — Choose a starting config"

  printf '\n'
  printf '         Which starting config do you want?\n\n'
  printf '         1) Use the included 800x600 preset\n'
  printf '            Pre-filled coordinates from a working 800x600 Gamescope setup.\n'
  printf '            Only works if your Gamescope window is 800x600 and your\n'
  printf '            Roblox UI layout matches. If clicks land in the wrong place,\n'
  printf '            you will need to recalibrate.\n'
  printf '\n'
  printf '         2) Start blank and calibrate everything myself\n'
  printf '            Safer if your screen size or window size is different.\n'
  printf '            You fill in every coordinate yourself using xdotool.\n'
  printf '\n'
  printf '         Choice [1/2]: '
  local choice
  read -r choice
  choice="${choice:-2}"
  case "$choice" in
    1) apply_preset_800x600 ;;
    2) _apply_blank_config ;;
    *) print_warn "Unknown choice. Using blank config."; _apply_blank_config ;;
  esac
}

_apply_config_choice_missing_only() {
  print_info "Filling in missing config files only (existing files will not be changed)."
  print_info ""
  local preset_dir="$project_root/presets/800x600_known_good"
  local template_dir="$project_root/config_templates"
  local src_dir

  printf '         Which config to use for new files?\n'
  printf '         1) Use the included 800x600 preset for missing files\n'
  printf '         2) Use blank templates for missing files\n'
  printf '         Choice [1/2]: '
  local choice
  read -r choice
  choice="${choice:-2}"
  case "$choice" in
    1) src_dir="$preset_dir" ;;
    2) src_dir="$template_dir" ;;
    *) src_dir="$template_dir" ;;
  esac

  if ! test -d "$src_dir"; then
    print_warn "Source dir not found: $src_dir. Using templates."
    src_dir="$template_dir"
  fi

  local rel_file abs_src abs_dst dst_dir
  while IFS= read -r -d '' abs_src; do
    rel_file="${abs_src#$src_dir/}"
    abs_dst="$RC_DIR/$rel_file"
    if ! test -f "$abs_dst"; then
      dst_dir="${abs_dst%/*}"
      mkdir -p "$dst_dir"
      cp "$abs_src" "$abs_dst"
      print_info "Added: $rel_file"
    fi
  done < <(find "$src_dir" -type f -print0)

  print_ok "Missing files filled in."
}

apply_preset_800x600() {
  local preset_dir="$project_root/presets/800x600_known_good"

  if ! test -d "$preset_dir"; then
    print_warn "Preset directory not found: presets/800x600_known_good/"
    print_info "Falling back to blank config."
    _apply_blank_config
    return 0
  fi

  print_info "Copying 800x600 preset files into runtime_config/ ..."
  local rel_file abs_src abs_dst dst_dir
  while IFS= read -r -d '' abs_src; do
    rel_file="${abs_src#$preset_dir/}"
    abs_dst="$RC_DIR/$rel_file"
    dst_dir="${abs_dst%/*}"
    mkdir -p "$dst_dir"
    cp "$abs_src" "$abs_dst"
  done < <(find "$preset_dir" -type f -print0)

  print_ok "800x600 preset applied to runtime_config/."
  print_info ""
  print_info "IMPORTANT: These coordinates were calibrated at 800x600 Gamescope resolution."
  print_info "Start Gamescope with: gamescope -W 800 -H 600 -r 60 ..."
  print_info "If clicks land in the wrong place, you must recalibrate."
  print_info "See docs/CALIBRATION.md for how to recalibrate."
  print_info ""
  print_info "Recovery is OFF by default. Enable it only after setting your"
  print_info "private server URL and calibrating recovery button locations."
}

_apply_blank_config() {
  local template_dir="$project_root/config_templates"

  if ! test -d "$template_dir"; then
    print_warn "config_templates/ not found — cannot create blank config."
    return 1
  fi

  print_info "Copying blank templates into runtime_config/ ..."
  local rel_file abs_src abs_dst dst_dir
  while IFS= read -r -d '' abs_src; do
    rel_file="${abs_src#$template_dir/}"
    abs_dst="$RC_DIR/$rel_file"
    dst_dir="${abs_dst%/*}"
    mkdir -p "$dst_dir"
    cp "$abs_src" "$abs_dst"
  done < <(find "$template_dir" -type f -print0)

  print_ok "Blank config applied."
  print_info ""
  print_info "You must now open each file in runtime_config/ and fill in"
  print_info "your screen coordinates before running the macro."
  print_info "See docs/CALIBRATION.md for step-by-step instructions."
}

# ── Private server URL ────────────────────────────────────────────────────────

setup_private_server_url() {
  print_header "Step 7 — Optional: Private server URL for recovery restarts"

  print_info "If you want ACC to automatically rejoin a private server after a"
  print_info "crash or long session, you can save your private server URL now."
  print_info ""
  print_info "You can skip this step and add it later by editing:"
  print_info "  runtime_config/recovery/defaults.conf"
  print_info ""

  if test "$DRY_RUN" = "1"; then
    print_info "[dry-run] Would ask whether to set a private server URL."
    print_info "[dry-run] If yes, would write it to runtime_config/recovery/defaults.conf"
    print_info "[dry-run] The URL would never be printed again after storing."
    return 0
  fi

  if ! ask_yes_no "Set a private server URL now?" "n"; then
    print_info "Skipped. Add it later in runtime_config/recovery/defaults.conf if needed."
    return 0
  fi

  local url
  printf '         Paste your private server URL (will not be shown again): '
  read -r url

  if test -z "$url"; then
    print_warn "No URL entered. Skipping."
    return 0
  fi

  local rec_dir="$RC_DIR/recovery"
  local rec_defaults="$rec_dir/defaults.conf"
  mkdir -p "$rec_dir"

  if test -f "$rec_defaults"; then
    local tmp_file
    tmp_file="$(mktemp)"
    grep -v '^RECOVERY_PRIVATE_SERVER_URL=' "$rec_defaults" > "$tmp_file" || true
    printf "RECOVERY_PRIVATE_SERVER_URL='%s'\n" "$url" >> "$tmp_file"
    mv "$tmp_file" "$rec_defaults"
  else
    if test -f "$project_root/config_templates/recovery/defaults.conf"; then
      cp "$project_root/config_templates/recovery/defaults.conf" "$rec_defaults"
    fi
    printf "RECOVERY_PRIVATE_SERVER_URL='%s'\n" "$url" >> "$rec_defaults"
  fi

  print_ok "Private server URL saved to runtime_config/recovery/defaults.conf [configured]"
  print_info ""
  print_info "Recovery is still OFF by default (RECOVERY_ENABLED=0)."
  print_info "To enable it, edit runtime_config/recovery/defaults.conf"
  print_info "and set RECOVERY_ENABLED=1 after calibrating recovery button locations."
  print_info "See docs/CALIBRATION.md for the recovery point list."
}

# ── Validation ────────────────────────────────────────────────────────────────

run_validation() {
  print_header "Step 8 — Non-live validation checks"

  print_info "Running syntax and config checks only. No live input will be sent."
  print_info ""

  local failed=0

  # Syntax check
  printf '  Checking script syntax (bash -n) ...\n'
  local syntax_ok=1
  bash -n \
    "$project_root/bin/acc" \
    "$project_root/bin/pack-opener-ui" \
    "$project_root/bin/macroctl" \
    "$project_root/bin/setup-acc" \
    2>&1 | sed 's/^/    /' || syntax_ok=0

  local module_sh lib_sh
  for module_sh in "$project_root/src/modules/"*.sh; do
    test -f "$module_sh" && bash -n "$module_sh" 2>&1 | sed 's/^/    /' || syntax_ok=0
  done
  for lib_sh in "$project_root/src/lib/"*.sh; do
    test -f "$lib_sh" && bash -n "$lib_sh" 2>&1 | sed 's/^/    /' || syntax_ok=0
  done

  if test "$syntax_ok" = "1"; then
    print_ok "Syntax check passed"
  else
    print_warn "Syntax check found issues (see above)"
    failed=1
  fi

  # Status check
  printf '\n  Running: macroctl status\n'
  if MACRO_PROJECT_ROOT="$project_root" "$project_root/bin/macroctl" status 2>&1 | sed 's/^/    /'; then
    print_ok "macroctl status"
  else
    print_warn "macroctl status returned non-zero (expected if Gamescope is not running)"
    failed=1
  fi

  # Validate config
  printf '\n  Running: macroctl validate-config pack-opener\n'
  if MACRO_PROJECT_ROOT="$project_root" "$project_root/bin/macroctl" validate-config pack-opener 2>&1 | sed 's/^/    /'; then
    print_ok "validate-config pack-opener"
  else
    print_warn "validate-config pack-opener found issues (calibrate coordinates if using blank config)"
    failed=1
  fi

  printf '\n  Running: macroctl validate-config orchestrator\n'
  if MACRO_PROJECT_ROOT="$project_root" "$project_root/bin/macroctl" validate-config orchestrator 2>&1 | sed 's/^/    /'; then
    print_ok "validate-config orchestrator"
  else
    print_warn "validate-config orchestrator found issues"
    failed=1
  fi

  printf '\n  Running: macroctl validate-config recovery\n'
  if MACRO_PROJECT_ROOT="$project_root" "$project_root/bin/macroctl" validate-config recovery 2>&1 | sed 's/^/    /'; then
    print_ok "validate-config recovery"
  else
    print_warn "validate-config recovery found issues"
    failed=1
  fi

  printf '\n  Running: macroctl dry-run orchestrator --cycles 3\n'
  if MACRO_INPUT_MODE=dry-run MACRO_PROJECT_ROOT="$project_root" \
      "$project_root/bin/macroctl" dry-run orchestrator --cycles 3 2>&1 | sed 's/^/    /'; then
    print_ok "dry-run orchestrator"
  else
    print_warn "dry-run orchestrator returned issues"
    failed=1
  fi

  printf '\n  Running: macroctl dry-run recovery\n'
  if MACRO_INPUT_MODE=dry-run MACRO_PROJECT_ROOT="$project_root" \
      "$project_root/bin/macroctl" dry-run recovery 2>&1 | sed 's/^/    /'; then
    print_ok "dry-run recovery"
  else
    print_warn "dry-run recovery returned issues (expected if recovery is not yet configured)"
  fi

  printf '\n'
  if test "$failed" = "0"; then
    print_ok "All non-live checks passed."
  else
    print_warn "Some checks had warnings — see output above."
    print_info "Warnings are expected when runtime_config/ is not yet calibrated."
    print_info "The macro will not work correctly until all coordinates are filled in."
  fi
}

# ── Status check (--check mode) ───────────────────────────────────────────────

show_status() {
  print_header "ACC System and Config Status"

  printf '  OS:  %s\n' "$OS_PRETTY"
  if test "$IS_UBUNTU_LIKE" = "1"; then
    print_ok "Pop!_OS / Ubuntu-based — supported"
  else
    print_warn "Not Pop!_OS / Ubuntu-based — may need manual setup"
  fi

  printf '\n  Package manager:\n'
  if test "$HAS_APT" = "1"; then
    print_ok "apt — Available (automatic install supported)"
  else
    print_warn "apt — Not found (manual install required)"
  fi

  print_header "Programs"
  check_dependencies

  print_header "Sober (Roblox client)"
  if command_exists flatpak; then
    check_sober
    if test "$IS_UBUNTU_LIKE" = "1" && test "$SOBER_INSTALLED" = "0"; then
      print_info "Install with: flatpak install flathub org.vinegarhq.Sober"
    fi
  else
    print_miss "flatpak — Not installed (required to check or install Sober)"
  fi

  print_header "Local config (runtime_config/)"
  if test -d "$RC_DIR"; then
    print_ok "runtime_config/ — Exists"
    _report_config_status
  else
    print_miss "runtime_config/ — Not found"
    print_info "Run ./bin/setup-acc to create it."
  fi
  printf '\n'
}

_report_config_status() {
  local po_pts="$RC_DIR/pack_opener/points.conf"
  if test -f "$po_pts"; then
    local blank filled
    blank="$(grep -cE '=$' "$po_pts" || true)"
    filled="$(grep -cE '=[^[:space:]]' "$po_pts" || true)"
    if test "${filled:-0}" -eq 0; then
      print_warn "pack_opener/points.conf — Needs calibration (all points blank)"
    elif test "${blank:-0}" -gt 0; then
      print_warn "pack_opener/points.conf — Partially calibrated ($filled filled, $blank blank)"
    else
      print_ok "pack_opener/points.conf — Configured ($filled points)"
    fi
  else
    print_miss "pack_opener/points.conf — Not found"
  fi

  local rec_def="$RC_DIR/recovery/defaults.conf"
  if test -f "$rec_def"; then
    local rec_url
    rec_url="$(grep -E '^RECOVERY_PRIVATE_SERVER_URL=' "$rec_def" | tail -n1 | cut -d= -f2- || true)"
    rec_url="${rec_url#\'}"
    rec_url="${rec_url%\'}"
    if test -n "$rec_url"; then
      print_ok "recovery/defaults.conf — Private server URL: Configured"
    else
      print_warn "recovery/defaults.conf — Private server URL: Not configured (recovery will not work)"
    fi
  else
    print_miss "recovery/defaults.conf — Not found"
  fi
}

# ── Finish screen ─────────────────────────────────────────────────────────────

show_next_steps() {
  print_header "Setup complete — What to do next"

  printf '  1. Start Gamescope with Sober inside it:\n'
  printf '\n'
  printf '       gamescope -W 800 -H 600 -r 60 --force-grab-cursor -- \\\n'
  printf '         flatpak run org.vinegarhq.Sober\n'
  printf '\n'
  printf '  2. Make sure Gamescope attached to DISPLAY=:1\n'
  printf '     Check with: DISPLAY=:1 xdotool getmouselocation --shell\n'
  printf '\n'
  printf '  3. Open the macro panel:\n'
  printf '       ./bin/acc\n'
  printf '\n'
  printf '  4. Check module status before running anything live.\n'
  printf '     Use Module Status / Macro Status inside the UI.\n'
  printf '\n'
  printf '  5. Start with pack opener only.\n'
  printf '     Watch it run a few cycles. If clicks land correctly, enable\n'
  printf '     market buyer and figurines buyer one at a time.\n'
  printf '\n'
  printf '  6. If clicks land in the wrong place, recalibrate coordinates.\n'
  printf '     See: docs/CALIBRATION.md\n'
  printf '\n'
  printf '  Not checked live — confirm everything works before a long run.\n'
  printf '\n'
}

# ── Help ──────────────────────────────────────────────────────────────────────

show_help() {
  cat <<'EOF'
ACC Setup — Pop!_OS setup wizard

Usage:
  ./bin/setup-acc              Run the full interactive setup
  ./bin/setup-acc --check      Check system and config status (no installs, no writes)
  ./bin/setup-acc --dry-run    Print what the setup would do, without doing anything
  ./bin/setup-acc --help       Show this help

What this setup does:
  - Checks your OS and installed programs
  - Offers to install missing programs using apt (will ask before running sudo)
  - Offers to install Sober (Roblox via Flatpak)
  - Creates your local runtime_config/ folder
  - Lets you choose between the 800x600 preset or a blank config
  - Optionally stores a private server URL for the recovery module
  - Runs non-live validation checks

What this setup does NOT do:
  - Does not run the live macro
  - Does not start Sober or Gamescope
  - Does not send any mouse or keyboard input
  - Does not push or commit any files
  - Does not store your private server URL in any committed file

The 800x600 preset:
  Includes pre-filled coordinates from a working 800x600 Gamescope+Sober setup.
  Only use this preset if your Gamescope window is also 800x600 and the Roblox
  UI layout matches. If clicks miss, recalibrate using docs/CALIBRATION.md.

After setup:
  1. Start Gamescope with Sober inside it
  2. Confirm it attached to DISPLAY=:1
  3. Run ./bin/acc and check module status before going live

EOF
}

# ── Main ──────────────────────────────────────────────────────────────────────

main() {
  local arg="${1:-}"

  case "$arg" in
    --help|-h)
      show_help
      exit 0
      ;;
    --check)
      detect_os
      show_status
      exit 0
      ;;
    --dry-run)
      DRY_RUN=1
      ;;
    "")
      ;;
    *)
      printf 'Unknown option: %s\n' "$arg" >&2
      printf 'Run ./bin/setup-acc --help for usage.\n' >&2
      exit 2
      ;;
  esac

  # ── Dry-run mode: non-interactive summary ─────────────────────────────────

  if test "$DRY_RUN" = "1"; then
    printf '\n\033[1;33m[DRY-RUN] Nothing will be installed or written.\033[0m\n'
    detect_os

    print_header "Step 1 — System check"
    printf '  OS: %s\n' "$OS_PRETTY"
    if test "$IS_UBUNTU_LIKE" = "1"; then
      print_ok "Pop!_OS / Ubuntu-based — supported"
    else
      print_warn "Not Pop!_OS / Ubuntu-based"
    fi

    print_header "Step 2 — Required programs"
    check_dependencies

    print_header "Step 3 — Install missing programs"
    install_dependencies

    print_header "Step 4 — Sober (Roblox client)"
    if command_exists flatpak; then
      check_sober
    else
      print_miss "flatpak not found"
    fi
    install_sober

    setup_runtime_config
    setup_private_server_url

    print_header "Step 8 — Validation"
    print_info "[dry-run] Would run:"
    print_info "  bash -n bin/acc bin/pack-opener-ui bin/macroctl bin/setup-acc"
    print_info "  bash -n src/modules/*.sh src/lib/*.sh"
    print_info "  ./bin/macroctl status"
    print_info "  ./bin/macroctl validate-config pack-opener"
    print_info "  ./bin/macroctl validate-config orchestrator"
    print_info "  ./bin/macroctl validate-config recovery"
    print_info "  ./bin/macroctl dry-run orchestrator --cycles 3"
    print_info "  ./bin/macroctl dry-run recovery"
    printf '\n'
    print_ok "[dry-run] Dry-run complete. No changes were made."
    printf '\n'
    exit 0
  fi

  # ── Interactive mode ──────────────────────────────────────────────────────

  printf '\n'
  printf '\033[1;34m┌──────────────────────────────────────┐\033[0m\n'
  printf '\033[1;34m│          ACC Setup Wizard            │\033[0m\n'
  printf '\033[1;34m└──────────────────────────────────────┘\033[0m\n'
  printf '\n'
  printf 'This wizard sets up ACC on your Pop!_OS machine.\n'
  printf '\n'
  printf 'What this does:\n'
  printf '  - Checks your system and installed programs\n'
  printf '  - Installs missing programs (will ask before running sudo)\n'
  printf '  - Sets up your local config folder\n'
  printf '  - Runs non-live checks to confirm everything looks right\n'
  printf '\n'
  printf 'What this does NOT do:\n'
  printf '  - Does not run the live macro\n'
  printf '  - Does not start Sober or Gamescope\n'
  printf '  - Does not send any mouse or keyboard input\n'
  printf '\n'

  if ! ask_yes_no "Ready to continue?" "y"; then
    printf 'Setup cancelled.\n'
    exit 0
  fi

  # Step 1 — OS check
  print_header "Step 1 — Checking your system"
  detect_os
  printf '  OS: %s\n' "$OS_PRETTY"
  printf '\n'
  if test "$IS_UBUNTU_LIKE" = "1"; then
    print_ok "Looks like Pop!_OS or Ubuntu — fully supported."
  else
    print_warn "This does not look like Pop!_OS or Ubuntu."
    print_info "ACC should still work, but automatic package install may not be available."
    print_info ""
    if ! ask_yes_no "Continue anyway?" "y"; then
      printf 'Setup cancelled.\n'
      exit 0
    fi
  fi

  # Step 2 — Dependency check
  print_header "Step 2 — Checking required programs"
  check_dependencies

  # Step 3 — Install missing deps (if any)
  if test "${#DEPS_MISSING[@]}" -gt 0; then
    install_dependencies
  fi

  # Step 4 — Sober
  print_header "Step 4 — Checking Sober (Roblox client)"
  if command_exists flatpak; then
    check_sober
    if test "$SOBER_INSTALLED" = "0"; then
      printf '\n'
      install_sober
    fi
  else
    print_miss "flatpak is not installed — cannot check or install Sober."
    print_info "Install flatpak first, then run:"
    print_info "  flatpak install flathub org.vinegarhq.Sober"
  fi

  # Step 5-6 — Runtime config
  setup_runtime_config

  # Step 7 — Private server URL
  setup_private_server_url

  # Step 8 — Validation
  run_validation

  # Done
  show_next_steps
}

main "$@"

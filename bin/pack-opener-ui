# ── Status / info screens ─────────────────────────────────────────────────────

changed_summary() {
  local out
  out="$(git -C "$PROJECT_ROOT" status --short 2>/dev/null || true)"
  if test -z "$out"; then
    printf 'clean'
  else
    printf 'has changes'
  fi
}

print_status_screen() {
  local branch
  local commit

  branch="$(git -C "$PROJECT_ROOT" branch --show-current 2>/dev/null || printf '<unknown>')"
  commit="$(git -C "$PROJECT_ROOT" log -1 --oneline 2>/dev/null || printf '<unknown>')"

  printf '%sACC STATUS%s\n\n' "$BOLD$CYAN" "$RESET"
  printf '%sMacro:%s\n' "$MAGENTA" "$RESET"
  printf '%s\n' '- Mode: Full Macro (orchestrator)'
  printf '%s\n' '- Pack cycle: base → potion → pack (one at a time)'
  printf '%s\n' '- Buyer schedule: Market Buyer → Figurines Buyer every 10 minutes'
  printf '%s\n' '- Stop: Ctrl+C'
  printf '%s\n\n' '- One cycle: go to base, use potions, walk and place packs'
  printf '%sModule toggles (this session):%s\n' "$MAGENTA" "$RESET"
  printf '%s\n' "- Pack Opener:     $(on_off "$TOGGLE_PACK_OPENER")"
  printf '%s\n' "- Market Buyer:    $(on_off "$TOGGLE_MARKET_BUYER")"
  printf '%s\n' "- Figurines Buyer: $(on_off "$TOGGLE_FIGURINES_BUYER")"
  printf '%s\n' '- Star Trials:     OFF (imported/legacy — not available for live runs)'
  printf '%s\n\n' "- Recovery Restart: $(on_off "$TOGGLE_RECOVERY_RESTART")"

  printf '%sRecovery Restart:%s\n' "$MAGENTA" "$RESET"
  local rec_interval rec_wait rec_url_status rec_points_status
  rec_interval="$(recovery_config_get RECOVERY_INTERVAL_MINUTES)"
  rec_wait="$(recovery_config_get RECOVERY_POST_LAUNCH_WAIT)"
  printf '%s\n' "- Enabled (this session): $(on_off "$TOGGLE_RECOVERY_RESTART")"
  printf '%s\n' "- Interval: ${rec_interval:-120} minutes"
  printf '%s\n' "- Post-launch wait: ${rec_wait:-10m}"
  if recovery_url_configured; then
    rec_url_status="[configured]"
  else
    rec_url_status="<not configured — set RECOVERY_PRIVATE_SERVER_URL in runtime_config/recovery/defaults.conf>"
  fi
  printf '%s\n' "- Private server URL: $rec_url_status"
  if recovery_required_points_configured; then
    rec_points_status="configured"
  else
    rec_points_status="<not configured — set RECOVERY_POPUP_CLOSE_BUTTON_X/Y and RECOVERY_ITEMS_TAB_BUTTON_X/Y in runtime_config/recovery/points.conf>"
  fi
  printf '%s\n\n' "- Recovery points: $rec_points_status"

  printf '%sPotions:%s\n' "$MAGENTA" "$RESET"
  printf '%s\n' "- Potions: $(on_off "$(plan_value POTION_PLAN_ENABLED)")"
  printf '%s\n' "- 2-minute amount: $(plan_value POTION_2_MIN_USE_AMOUNT)"
  printf '%s\n' "- Potion click speed: $(plan_value POTION_CLICK_INTERVAL)"
  printf '%s\n' "- Base-to-inventory wait: $(timing_value POTION_PRE_MENU_CLICK_WAIT)"
  printf '%s\n\n' "- Inventory-to-potion wait: $(timing_value POST_INVENTORY_OPEN_WAIT)"

  printf '%sWalking:%s\n' "$MAGENTA" "$RESET"
  printf '%s\n' "- Forward duration: $(timing_value PLACE_FORWARD_DURATION)"
  printf '%s\n' "- Left duration: $(timing_value PLACE_LEFT_DURATION)"
  printf '%s\n\n' "- Extra E taps: $(on_off "$(timing_value PLACE_LIVE_E_ENABLED)")"

  printf '%sImportant buttons:%s\n' "$MAGENTA" "$RESET"
  printf '%s\n' "- Base button: $(point_value BASE_TELEPORT_BUTTON)"
  printf '%s\n' "- Inventory button: $(point_value MENU_BUTTON)"
  printf '%s\n' "- 2-minute potion: $(point_value POTION_2_MIN)"
  printf '%s\n' "- 10x use button: $(point_value POTION_2_MIN_USE_10X_BUTTON)"
  printf '%s\n\n' "- Pack click point: $(point_value PACK_CLICK_POINT)"

  printf '%sProject:%s\n' "$MAGENTA" "$RESET"
  printf '%s\n' "- Branch: ${branch:-<unknown>}"
  printf '%s\n' "- Latest commit: $commit"
  printf '%s\n' "- Changes: $(changed_summary)"
}

print_stop_screen() {
  printf '%sStop / How to stop%s\n\n' "$BOLD$CYAN" "$RESET"
  printf 'The macro runs in the foreground of this terminal.\n'
  printf 'No background processes are started.\n\n'
  printf '%sTo stop the macro:%s\n' "$BOLD" "$RESET"
  printf '  Press %sCtrl+C%s while the macro is running.\n\n' "$BOLD$YELLOW" "$RESET"
  printf 'The macro will stop after the current action completes.\n'
  printf 'Your log is saved automatically.\n\n'
  printf '%sNothing runs after you close this app.%s\n' "$GREY" "$RESET"
}

print_modules_screen() {
  printf '%sMacro Modules%s\n\n' "$BOLD$CYAN" "$RESET"
  printf '%s[READY        ]%s Pack Opener\n' "$GREEN" "$RESET"
  printf '               Repeats one cycle at a time inside orchestrator\n'
  printf '%s               Potion runner integrated%s\n\n' "$GREY" "$RESET"
  buyer_module_label "$TOGGLE_MARKET_BUYER" "$MARKET_BUYER_POINTS_FILE" "Market Buyer"
  printf '%s               Runs at every 10-min boundary%s\n\n' "$GREY" "$RESET"
  buyer_module_label "$TOGGLE_FIGURINES_BUYER" "$FIGURINES_BUYER_POINTS_FILE" "Figurines Buyer"
  printf '%s               Was: Shop Buyer — runs at every 10-min boundary%s\n\n' "$GREY" "$RESET"
  printf '%s[OFF          ]%s Star Trials\n' "$YELLOW" "$RESET"
  printf '%s               Imported / legacy / experimental — not enabled for live runs%s\n\n' "$GREY" "$RESET"
  recovery_module_label "$TOGGLE_RECOVERY_RESTART" "Recovery Restart"
  printf '%s               Optional Sober restart every N minutes to recover from long-session lag%s\n\n' "$GREY" "$RESET"
  printf '%s[READY        ]%s Orchestrator — 10-Minute Combo Scheduler\n' "$GREEN" "$RESET"
  printf '%s               Runs pack opener continuously;\n' "$GREY"
  printf '               at :00/:10/:20/:30/:40/:50 runs Market Buyer then Figurines Buyer;%s\n' "$RESET"
  printf '%s               recovery restart runs after buyers when interval is due%s\n' "$GREY" "$RESET"
}

print_project_status() {
  local branch
  local commit
  local status

  branch="$(git -C "$PROJECT_ROOT" branch --show-current 2>/dev/null || printf '<unknown>')"
  commit="$(git -C "$PROJECT_ROOT" log -1 --oneline 2>/dev/null || printf '<unknown>')"
  status="$(git -C "$PROJECT_ROOT" status --short 2>/dev/null || true)"

  printf '%sPROJECT STATUS%s\n\n' "$BOLD$CYAN" "$RESET"
  printf 'Branch:\n%s\n\n' "${branch:-<unknown>}"
  printf 'Latest commit:\n%s\n\n' "$commit"
  printf 'Changed files:\n'
  if test -z "$status"; then
    printf 'clean\n'
  else
    printf '%s\n' "$status"
  fi
}

# ── Validation helpers ────────────────────────────────────────────────────────

validate_cycles_1_to_3() {
  local cycles="$1"
  if ! [[ "$cycles" =~ ^[1-3]$ ]]; then
    printf 'Please choose 1, 2, or 3 cycles.\n' >&2
    return 2
  fi
}

# ── Log helpers ───────────────────────────────────────────────────────────────

new_log_file() {
  local kind="$1"
  mkdir -p "$LOG_DIR"
  printf '%s/pack_opener_ui_%s_%s.txt' "$LOG_DIR" "$kind" "$(date +%Y%m%d-%H%M%S)"
}

now_ms() {
  date +%s%3N
}

copy_log_if_possible() {
  local log_file="$1"
  if command -v wl-copy >/dev/null 2>&1; then
    if wl-copy < "$log_file" 2>/dev/null; then
      printf '\nThe log was copied to your clipboard.\n'
    else
      printf '\nClipboard copy skipped because wl-copy could not access the clipboard.\n'
    fi
  else
    printf '\nClipboard copy skipped because wl-copy was not found.\n'
  fi
  return 0
}

finish_run_message() {
  local status="$1"
  local log_file="$2"

  if test "$status" -eq 0; then
    status_label="COMPLETE"
    printf '\n%sRun complete.%s\n' "$GREEN" "$RESET"
  else
    status_label="FAILED"
    printf '\n%sRun stopped or failed.%s\n' "$RED" "$RESET"
  fi
  printf 'Log saved to:\n%s\n' "$log_file"
  copy_log_if_possible "$log_file"
  if test "$status" -ne 0; then
    printf '\nCheck the last lines of the log before running again.\n'
  fi
}

# ── Dry run ───────────────────────────────────────────────────────────────────

run_dry_cycles() {
  local cycles="$1"
  local log_file
  local start_ms
  local end_ms
  local status

  validate_cycles_1_to_3 "$cycles" || return $?
  log_file="$(new_log_file dry_run)"
  start_ms="$(now_ms)"
  status_label="DRY RUN"

  printf '%sTest without clicking%s\n' "$YELLOW" "$RESET"
  printf 'This checks what the macro would do, but does not control the game.\n'
  printf 'Cycles: %s\n\n' "$cycles"

  "$MACROCTL" dry-run live-cycle --cycles "$cycles" > "$log_file" 2>&1
  status=$?
  end_ms="$(now_ms)"
  printf 'elapsed_ms=%s\n' "$((end_ms - start_ms))" >> "$log_file"
  finish_run_message "$status" "$log_file"
  return "$status"
}

run_dry_cycles_with_trace() {
  local cycles="$1"
  local log_file
  local start_ms
  local end_ms
  local status

  validate_cycles_1_to_3 "$cycles" || return $?
  log_file="$(new_log_file dry_run)"
  start_ms="$(now_ms)"
  status_label="DRY RUN"

  printf '%sTest without clicking (timing trace)%s\n' "$YELLOW" "$RESET"
  printf 'This checks timing data, but does not control the game.\n'
  printf 'Cycles: %s\n\n' "$cycles"

  MACRO_TRACE_TIMING=1 "$MACROCTL" dry-run live-cycle --cycles "$cycles" > "$log_file" 2>&1
  status=$?
  end_ms="$(now_ms)"
  printf 'elapsed_ms=%s\n' "$((end_ms - start_ms))" >> "$log_file"
  finish_run_message "$status" "$log_file"
  return "$status"
}

# ── Live runs ─────────────────────────────────────────────────────────────────

live_countdown() {
  local label="$1"
  if test "$use_animation" -eq 1; then
    printf '%s IN 3\n' "$label"
    sleep 1
    printf '%s IN 2\n' "$label"
    sleep 1
    printf '%s IN 1\n' "$label"
    sleep 1
  fi
  printf '%s\n' "$label"
}

confirm_live_run() {
  local typed

  printf '%sLIVE RUN WARNING%s\n\n' "$BOLD$YELLOW" "$RESET"
  cat <<'EOF'
This will control the game.
Make sure:
- Sober/Gamescope is open and visible.
- The game is at the normal starting screen.
- Inventory is closed.
- You are ready for the macro to click and move.

Type RUN LIVE to start.
Press Enter without typing it to cancel.
>
EOF
  read -r typed
  test "$typed" = "RUN LIVE"
}

run_live_batch() {
  local cycles="$1"
  local log_file="$2"

  MACRO_INPUT_MODE=live \
    MACRO_LIVE_INPUT_ALLOWED=1 \
    MACRO_LIVE_CYCLE_RUNNER_CONFIRM=YES \
    "$MACROCTL" live live-cycle --cycles "$cycles" >> "$log_file" 2>&1
}

run_live_cycles() {
  local cycles="$1"
  local log_file
  local start_ms
  local end_ms
  local status

  validate_cycles_1_to_3 "$cycles" || return $?
  if ! confirm_live_run; then
    printf 'Cancelled.\n'
    return 1
  fi

  log_file="$(new_log_file live)"
  start_ms="$(now_ms)"
  status_label="LIVE ARMED"
  live_countdown RUNNING
  status_label="RUNNING"

  run_live_batch "$cycles" "$log_file"
  status=$?
  end_ms="$(now_ms)"
  printf 'elapsed_ms=%s\n' "$((end_ms - start_ms))" >> "$log_file"
  finish_run_message "$status" "$log_file"
  return "$status"
}

confirm_run_until_stopped() {
  local typed

  printf '%sRUN UNTIL STOPPED WARNING%s\n\n' "$BOLD$YELLOW" "$RESET"
  cat <<'EOF'
This will keep controlling the game until you stop it.
ACC repeats complete cycles until stopped, with no delay between cycles.

What will run:
  Pack Opener — continuous mode
  One cycle: base → use potions → walk and place packs
  Repeats until you stop it

How to stop:
  Press Ctrl+C while the macro is running.

Make sure:
- Sober/Gamescope is open and visible.
- Inventory is closed.
- You can stop the run with Ctrl+C.

Type RUN UNTIL STOPPED to start.
Press Enter without typing it to cancel.
>
EOF
  read -r typed
  test "$typed" = "RUN UNTIL STOPPED"
}

request_stop_until_stopped() {
  ACC_STOP_REQUESTED=1
}

# One continuous live runner process that loops complete single cycles forever
# (base -> potion -> placement) until Ctrl+C or a cycle fails. The cycle loop
# lives in one process: no repeated macroctl launches and no between-cycle pause.
run_live_until_stopped() {
  local log_file="$1"

  MACRO_INPUT_MODE=live \
    MACRO_LIVE_INPUT_ALLOWED=1 \
    MACRO_LIVE_CYCLE_RUNNER_CONFIRM=YES \
    "$MACROCTL" live live-cycle --until-stopped >> "$log_file" 2>&1
}

run_until_stopped() {
  local log_file
  local start_ms
  local end_ms
  local status=0
  local start_stamp
  local old_int_trap

  if ! confirm_run_until_stopped; then
    printf 'Cancelled.\n'
    return 1
  fi

  ACC_STOP_REQUESTED=0
  old_int_trap="$(trap -p INT || true)"
  trap 'request_stop_until_stopped' INT

  log_file="$(new_log_file live_until_stopped)"
  start_ms="$(now_ms)"
  start_stamp="$(date +%Y-%m-%dT%H:%M:%S%z)"
  printf 'start_timestamp=%s\n' "$start_stamp" >> "$log_file"
  printf 'mode=until_stopped\n' >> "$log_file"
  printf 'between_cycle_pause=none\n' >> "$log_file"

  status_label="LIVE ARMED"
  live_countdown RUNNING
  status_label="RUNNING"

  show_running_side_profile

  # Single live runner process loops cycles internally; ACC does not batch.
  run_live_until_stopped "$log_file"
  status=$?

  if test "$ACC_STOP_REQUESTED" -ne 0; then
    printf 'stopped_by_user=1\n' >> "$log_file"
    status_label="STOPPED"
    if test "$status" -eq 0; then
      status=130
    fi
  fi

  if test -n "$old_int_trap"; then
    eval "$old_int_trap"
  else
    trap - INT
  fi

  end_ms="$(now_ms)"
  printf 'elapsed_ms=%s\n' "$((end_ms - start_ms))" >> "$log_file"

  if test "$status" -eq 130; then
    status_label="STOPPED"
    printf '\n%sStopped by user.%s\n' "$YELLOW" "$RESET"
    printf 'Log saved to:\n%s\n' "$log_file"
    copy_log_if_possible "$log_file"
    return 0
  else
    finish_run_message "$status" "$log_file"
    return "$status"
  fi
}

# ── Logs screen ───────────────────────────────────────────────────────────────

latest_logs() {
  find "$LOG_DIR" -maxdepth 1 -type f -printf '%T@ %p\n' 2>/dev/null \
    | sort -rn \
    | head -n 10 \
    | sed 's/^[^ ]* //'
}

print_latest_logs_list() {
  local files
  local i=1

  printf '%sLATEST LOGS%s\n\n' "$BOLD$CYAN" "$RESET"
  files="$(latest_logs)"
  if test -z "$files"; then
    printf 'No logs found in %s\n' "$LOG_DIR"
    return
  fi

  while IFS= read -r file; do
    printf '%s) %s\n' "$i" "$(basename "$file")"
    i=$((i + 1))
  done <<< "$files"
}

show_logs_screen() {
  local files
  local choice
  local number
  local selected

  while true; do
    files="$(latest_logs)"
    clear_screen
    print_latest_logs_list
    printf '\nType a number to open a log.\n'
    printf 'Type c and a number to copy it.\n'
    printf 'Type q to go back.\n> '
    read -r choice

    case "$choice" in
      q|Q)
        return
        ;;
      c\ *)
        number="${choice#c }"
        if ! [[ "$number" =~ ^[0-9]+$ ]]; then
          printf 'Please use c and a number, for example c 1.\n'
          pause_return
          continue
        fi
        selected="$(printf '%s\n' "$files" | sed -n "${number}p")"
        if test -z "$selected"; then
          printf 'No log exists for that number.\n'
          pause_return
          continue
        fi
        if command -v wl-copy >/dev/null 2>&1; then
          if wl-copy < "$selected" 2>/dev/null; then
            printf 'Copied %s to clipboard.\n' "$(basename "$selected")"
          else
            printf 'Clipboard copy skipped because wl-copy could not access the clipboard.\n'
          fi
        else
          printf 'Clipboard copy skipped because wl-copy was not found.\n'
        fi
        pause_return
        ;;
      *)
        if ! [[ "$choice" =~ ^[0-9]+$ ]]; then
          printf 'Please enter a number, c and a number, or q.\n'
          pause_return
          continue
        fi
        selected="$(printf '%s\n' "$files" | sed -n "${choice}p")"
        if test -z "$selected"; then
          printf 'No log exists for that number.\n'
          pause_return
          continue
        fi
        clear_screen
        printf '%s\n\n' "$selected"
        sed -n '1,220p' "$selected"
        pause_return
        ;;
    esac
  done
}


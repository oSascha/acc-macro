        launch_walking_path
        pause_return
        ;;
      10)
        show_logs_screen
        ;;
      11)
        clear_screen
        print_project_status
        pause_return
        ;;
      b|B)
        return
        ;;
      *)
        printf 'Please choose 1-11, or b to go back.\n'
        pause_return
        ;;
    esac
  done
}

# Check if a buyer's points file has all coordinates filled in.
# Returns 0 (configured) or 1 (missing/unconfigured).
buyer_points_configured() {
  local points_file="$1"
  if ! test -f "$points_file"; then
    return 1
  fi
  local val
  while IFS='=' read -r key val; do
    case "$key" in
      \#*|'') continue ;;
    esac
    if test -z "${val:-}"; then
      return 1
    fi
  done < "$points_file"
  return 0
}

# Returns a color-coded status label string for a buyer module.
buyer_module_label() {
  local toggle="$1"
  local points_file="$2"
  local name="$3"
  if test "$toggle" != "1"; then
    printf '%s[OFF          ]%s %s\n' "$YELLOW" "$RESET" "$name"
  elif buyer_points_configured "$points_file"; then
    printf '%s[READY        ]%s %s\n' "$GREEN" "$RESET" "$name"
  else
    printf '%s[NEEDS CALIB  ]%s %s\n' "$RED" "$RESET" "$name"
  fi
}

module_toggle_label() {
  local toggle="$1"
  local name="$2"
  if test "$toggle" = "1"; then
    printf '%s[ON ]%s %s\n' "$GREEN" "$RESET" "$name"
  else
    printf '%s[OFF]%s %s\n' "$YELLOW" "$RESET" "$name"
  fi
}

print_module_toggles_screen() {
  clear_screen
  small_logo
  printf '%s╔══════════════════════════════════════════════════════════════╗%s\n' "$MAGENTA" "$RESET"
  printf '%s║%s  %sMODULE TOGGLES%s                                             %s║%s\n' "$MAGENTA" "$RESET" "$BOLD$CYAN" "$RESET" "$MAGENTA" "$RESET"
  printf '%s╠══════════════════════════════════════════════════════════════╣%s\n' "$MAGENTA" "$RESET"
  printf '%s║%s  ' "$MAGENTA" "$RESET"
  module_toggle_label "$TOGGLE_PACK_OPENER" "Pack Opener        (press 1 to toggle)"
  printf '%s║%s  ' "$MAGENTA" "$RESET"
  module_toggle_label "$TOGGLE_MARKET_BUYER" "Market Buyer       (press 2 to toggle)"
  printf '%s║%s  ' "$MAGENTA" "$RESET"
  module_toggle_label "$TOGGLE_FIGURINES_BUYER" "Figurines Buyer    (press 3 to toggle)"
  printf '%s║%s  %s[OFF]%s Star Trials        %s(imported/legacy — not available for live run)%s\n' \
    "$MAGENTA" "$RESET" "$YELLOW" "$RESET" "$GREY" "$RESET"
  printf '%s║%s  ' "$MAGENTA" "$RESET"
  module_toggle_label "$TOGGLE_RECOVERY_RESTART" "Recovery Restart   (press 4 to toggle)"
  printf '%s║%s  ' "$MAGENTA" "$RESET"
  module_toggle_label "$TOGGLE_EVENT_VOTER" "Event Voter        (press 5 to toggle)"
  printf '%s╠══════════════════════════════════════════════════════════════╣%s\n' "$MAGENTA" "$RESET"
  printf '%s║%s  b) Back to main menu                                      %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"
  printf '%s╚══════════════════════════════════════════════════════════════╝%s\n' "$MAGENTA" "$RESET"
  printf '\nChoose: '
}

module_toggles_loop() {
  local choice

  while true; do
    print_module_toggles_screen
    read -r choice
    case "$choice" in
      1)
        if test "$TOGGLE_PACK_OPENER" = "1"; then
          TOGGLE_PACK_OPENER=0
        else
          TOGGLE_PACK_OPENER=1
        fi
        ;;
      2)
        if test "$TOGGLE_MARKET_BUYER" = "1"; then
          TOGGLE_MARKET_BUYER=0
        else
          TOGGLE_MARKET_BUYER=1
        fi
        ;;
      3)
        if test "$TOGGLE_FIGURINES_BUYER" = "1"; then
          TOGGLE_FIGURINES_BUYER=0
        else
          TOGGLE_FIGURINES_BUYER=1
        fi
        ;;
      4)
        if test "$TOGGLE_RECOVERY_RESTART" = "1"; then
          TOGGLE_RECOVERY_RESTART=0
        else
          TOGGLE_RECOVERY_RESTART=1
        fi
        ;;
      5)
        if test "$TOGGLE_EVENT_VOTER" = "1"; then
          TOGGLE_EVENT_VOTER=0
        else
          TOGGLE_EVENT_VOTER=1
        fi
        ;;
      b|B)
        return
        ;;
      *)
        printf 'Please choose 1-5 to toggle, or b to go back.\n'
        pause_return
        ;;
    esac
  done
}

# Returns 0 if the typed string is a valid start confirmation; 1 otherwise.
# Accepts: start, s, run, r, yes, y, START FULL MACRO, RUN FULL MACRO (case-insensitive).
# Rejects empty input so accidental Enter does not start.
full_macro_start_input_valid() {
  local typed="$1"
  # trim leading whitespace
  typed="${typed#"${typed%%[![:space:]]*}"}"
  # trim trailing whitespace
  typed="${typed%"${typed##*[![:space:]]}"}"
  if test -z "$typed"; then
    return 1
  fi
  # normalize to lowercase
  typed="$(printf '%s' "$typed" | tr '[:upper:]' '[:lower:]')"
  case "$typed" in
    s|start|r|run|y|yes|"start full macro"|"run full macro") return 0 ;;
    *) return 1 ;;
  esac
}

# Kill the orchestrator background job and mark stop requested.
_acc_stop_full_macro() {
  ACC_STOP_REQUESTED=1
  if test -n "$_acc_full_macro_orch_pid" && kill -0 "$_acc_full_macro_orch_pid" 2>/dev/null; then
    kill "$_acc_full_macro_orch_pid" 2>/dev/null || true
  fi
}

# Non-blocking key loop while the orchestrator runs in the background.
# Reads d/D to toggle dashboard, p/P to request pause, c/C to continue.
# Controls line is always printed via print_live_controls_line after every
# view draw, so it remains visible in both art and dashboard modes.
_acc_full_macro_key_loop() {
  local key ctrl_state last_ctrl_state
  local _dash_view=0     # 0=art  1=dashboard
  local _last_dash_sec=0 # epoch second of last dashboard draw
  local _need_redraw=1   # draw art/dashboard on first tick and after toggle
  last_ctrl_state=""

  while kill -0 "$_acc_full_macro_orch_pid" 2>/dev/null && test "$ACC_STOP_REQUESTED" -eq 0; do
    key=""
    IFS= read -rsn1 -t 0.2 key 2>/dev/null || true

    if test "$ACC_STOP_REQUESTED" -ne 0; then
      break
    fi

    case "${key:-}" in
      p|P)
        ctrl_state="$(orchestrator_control_get)"
        if test "$ctrl_state" = "running"; then
          orchestrator_control_request_pause
        fi
        ;;
      c|C)
        ctrl_state="$(orchestrator_control_get)"
        if test "$ctrl_state" = "paused"; then
          orchestrator_control_request_continue
        fi
        ;;
      d|D)
        if test "$_dash_view" = "0"; then
          _dash_view=1
        else
          _dash_view=0
        fi
        _need_redraw=1
        ;;
    esac

    ctrl_state="$(orchestrator_control_get)"
    local _state_changed=0
    if test "$ctrl_state" != "$last_ctrl_state"; then
      last_ctrl_state="$ctrl_state"
      _state_changed=1
    fi

    if test "$_dash_view" = "1"; then
      # Dashboard view: refresh at most once per second, or on toggle/state change.
      local _now_sec
      _now_sec="$(date +%s)"
      if test "$_need_redraw" = "1" || test "$_state_changed" = "1" \
         || test "$(( _now_sec - _last_dash_sec ))" -ge 1; then
        show_live_dashboard "$_full_macro_start_epoch" "$ctrl_state"
        _last_dash_sec="$_now_sec"
        _need_redraw=0
        print_live_controls_line "dash" "$ctrl_state"
      fi
    else
      # Art view: redraw art only on toggle (or first tick); controls on any change.
      if test "$_need_redraw" = "1"; then
        show_running_side_profile
        _need_redraw=0
        # Art was just redrawn — always reprint the controls line below it.
        _state_changed=1
      fi
      if test "$_state_changed" = "1"; then
        print_live_controls_line "art" "$ctrl_state"
      fi
    fi
  done
  printf '\n'
}

confirm_full_macro_run() {
  local typed

  printf '%sFULL MACRO WARNING%s\n\n' "$BOLD$YELLOW" "$RESET"
  printf 'This will run the full orchestrator — controlling the game until stopped.\n\n'
  printf 'Enabled modules:\n'
  if test "$TOGGLE_PACK_OPENER" = "1"; then
    printf '  %s+ Pack Opener%s  (continuous, one cycle at a time)\n' "$GREEN" "$RESET"
  fi
  if test "$TOGGLE_MARKET_BUYER" = "1"; then
    printf '  %s+ Market Buyer%s  (at 10-min boundaries)\n' "$GREEN" "$RESET"
  fi
  if test "$TOGGLE_FIGURINES_BUYER" = "1"; then
    printf '  %s+ Figurines Buyer%s  (at 10-min boundaries)\n' "$GREEN" "$RESET"
  fi
  printf '\nBuyer schedule: every 10 minutes (:00/:10/:20/:30/:40/:50)\n'
  printf 'Buyer order:    Market Buyer → Figurines Buyer\n\n'
  if test "$TOGGLE_MARKET_BUYER" = "1" && ! buyer_points_configured "$MARKET_BUYER_POINTS_FILE"; then
    printf '%sWARNING: Market Buyer is ON but points are not calibrated.%s\n' "$BOLD$RED" "$RESET"
    printf '%s         The macro will refuse to start. Disable it or calibrate first.%s\n\n' "$RED" "$RESET"
  fi
  if test "$TOGGLE_FIGURINES_BUYER" = "1" && ! buyer_points_configured "$FIGURINES_BUYER_POINTS_FILE"; then
    printf '%sWARNING: Figurines Buyer is ON but points are not calibrated.%s\n' "$BOLD$RED" "$RESET"
    printf '%s         The macro will refuse to start. Disable it or calibrate first.%s\n\n' "$RED" "$RESET"
  fi
  if test "$TOGGLE_RECOVERY_RESTART" = "1"; then
    local rec_interval rec_wait
    rec_interval="$(recovery_config_get RECOVERY_INTERVAL_MINUTES)"
    rec_wait="$(recovery_config_get RECOVERY_POST_LAUNCH_WAIT)"
    printf '  %s+ Recovery Restart%s  (every %s minutes)\n' "$GREEN" "$RESET" "${rec_interval:-120}"
    printf '    Will: open private server link via xdg-open\n'
    printf '          wait %s for game to load\n' "${rec_wait:-10m}"
    printf '          close first-login popup\n'
    printf '          press 1 to select pack\n'
    printf '          open inventory, click Items tab, close inventory\n'
    printf '          spam BASE_TELEPORT_BUTTON ×10 @ 15ms, then resume\n\n'
    if ! recovery_url_configured || ! recovery_required_points_configured; then
      printf '%sWARNING: Recovery Restart is ON but required config is missing.%s\n' "$BOLD$RED" "$RESET"
      printf '%s         The macro will refuse to start. Configure recovery or disable it.%s\n\n' "$RED" "$RESET"
    fi
  fi
  if test "$TOGGLE_EVENT_VOTER" = "1"; then
    local ev_times ev_priority ev_live
    ev_times="$(event_voter_config_get EVENT_VOTER_TIMES)"
    ev_priority="$(event_voter_config_get EVENT_VOTER_PRIORITY)"
    ev_live="$(event_voter_config_get EVENT_VOTER_LIVE_ALLOWED)"
    printf '  %s+ Event Voter%s  (experimental)\n' "$CYAN" "$RESET"
    printf '    Schedule: %s (Amsterdam)\n' "${ev_times:-07:00,07:20,07:40,19:00,19:20,19:40}"
    printf '    Priority: %s\n' "${ev_priority:-3x_xp,3x_mutation_chance}"
    if test "${ev_live:-0}" = "1"; then
      printf '    %sLIVE VOTING ARMED — will click real votes during event windows%s\n' "$BOLD$YELLOW" "$RESET"
    else
      printf '    Live voting: OFF (set EVENT_VOTER_LIVE_ALLOWED=1 to arm)\n'
    fi
    printf '    %sWARNING: Experimental — may click the wrong option occasionally.%s\n\n' "$RED" "$RESET"
  fi
  printf 'How to stop:\n'
  printf '  Press %sCtrl+C%s while the macro is running.\n\n' "$BOLD$YELLOW" "$RESET"
  printf 'Make sure:\n'
  printf '%s\n' '- Sober/Gamescope is open and visible.'
  printf '%s\n' '- The game is at the normal starting screen.'
  printf '%s\n\n' '- Inventory is closed.'
  printf 'Type %sstart%s or %ss%s to start.\n' "$BOLD" "$RESET" "$BOLD" "$RESET"
  printf 'Press Enter without typing to cancel.\n> '
  read -r typed
  if test -z "$typed"; then
    return 1
  fi
  full_macro_start_input_valid "$typed"
}

run_live_full_macro() {
  local output_target="$1"

  MACRO_INPUT_MODE=live \
    MACRO_LIVE_INPUT_ALLOWED=1 \
    MACRO_LIVE_CYCLE_RUNNER_CONFIRM=YES \
    ORCHESTRATOR_PACK_ENABLED="$TOGGLE_PACK_OPENER" \
    ORCHESTRATOR_MARKET_BUYER_ENABLED="$TOGGLE_MARKET_BUYER" \
    ORCHESTRATOR_FIGURINES_BUYER_ENABLED="$TOGGLE_FIGURINES_BUYER" \
    ORCHESTRATOR_RECOVERY_ENABLED="$TOGGLE_RECOVERY_RESTART" \
    ORCHESTRATOR_EVENT_VOTER_ENABLED="$TOGGLE_EVENT_VOTER" \
    "$MACROCTL" live orchestrator >> "$output_target" 2>&1
}

run_full_macro_until_stopped() {
  local log_file
  local output_target
  local start_ms
  local end_ms
  local status=0
  local start_stamp
  local old_int_trap

  if ! confirm_full_macro_run; then
    printf 'Cancelled.\n'
    return 1
  fi

  # Clear stale pause state before starting
  orchestrator_control_init

  _acc_full_macro_orch_pid=""
  _full_macro_start_epoch="$(date +%s)"
  ACC_STOP_REQUESTED=0
  old_int_trap="$(trap -p INT || true)"
  trap '_acc_stop_full_macro' INT

  start_ms="$(now_ms)"
  start_stamp="$(date +%Y-%m-%dT%H:%M:%S%z)"

  if test "$ACC_DEBUG_LOGS" = "1"; then
    log_file="$(new_log_file full_macro)"
    output_target="$log_file"
    printf 'start_timestamp=%s\n' "$start_stamp" >> "$log_file"
    printf 'mode=full_macro\n' >> "$log_file"
    printf 'pack_opener=%s\n' "$TOGGLE_PACK_OPENER" >> "$log_file"
    printf 'market_buyer=%s\n' "$TOGGLE_MARKET_BUYER" >> "$log_file"
    printf 'figurines_buyer=%s\n' "$TOGGLE_FIGURINES_BUYER" >> "$log_file"
  else
    log_file=""
    output_target="/dev/null"
  fi

  status_label="LIVE ARMED"
  live_countdown RUNNING
  status_label="RUNNING"

  # Background the orchestrator so the UI can read terminal keys for pause/resume
  run_live_full_macro "$output_target" &
  _acc_full_macro_orch_pid=$!

  if test "$interactive" -eq 1; then
    # key loop handles initial art draw via _force_redraw=1
    _acc_full_macro_key_loop
  fi

  wait "$_acc_full_macro_orch_pid" 2>/dev/null || status=$?
  _acc_full_macro_orch_pid=""

  if test "$ACC_STOP_REQUESTED" -ne 0; then
    if test -n "$log_file"; then
      printf 'stopped_by_user=1\n' >> "$log_file"
    fi
    status_label="STOPPED"
    status=130
  fi

  if test -n "$old_int_trap"; then
    eval "$old_int_trap"
  else
    trap - INT
  fi

  end_ms="$(now_ms)"
  if test -n "$log_file"; then
    printf 'elapsed_ms=%s\n' "$((end_ms - start_ms))" >> "$log_file"
  fi

  if test "$status" -eq 130; then
    status_label="STOPPED"
    printf '\n%sStopped by user.%s\n' "$YELLOW" "$RESET"
    if test -n "$log_file"; then
      printf 'Log saved to:\n%s\n' "$log_file"
      copy_log_if_possible "$log_file"
    fi
    return 0
  else
    if test -n "$log_file"; then
      finish_run_message "$status" "$log_file"
    else
      if test "$status" -eq 0; then
        status_label="COMPLETE"
        printf '\n%sRun complete.%s\n' "$GREEN" "$RESET"
      else
        status_label="FAILED"
        printf '\n%sRun stopped or failed.%s\n' "$RED" "$RESET"
      fi
    fi
    return "$status"
  fi
}

interactive_loop() {
  local choice

  startup_pulse
  while true; do
    main_menu
    read -r choice
    case "$choice" in
      1)
        sober_instance_loop
        ;;
      2)
        clear_screen
        run_full_macro_until_stopped
        pause_return
        ;;
      3)
        module_toggles_loop
        ;;
      4)
        clear_screen
        print_status_screen
        pause_return
        ;;
      5)
        clear_screen
        print_modules_screen
        pause_return
        ;;
      6)
        advanced_loop
        ;;
      q|Q)
        printf 'Stopped.\n'
        return 0
        ;;
      *)
        printf 'Please choose 1-6, or q.\n'
        pause_return
        ;;
    esac
  done
}

# ── Entry point ───────────────────────────────────────────────────────────────

case "${1:-}" in
  "")
    if test "$interactive" -ne 1; then
      usage
      exit 2
    fi
    interactive_loop
    ;;
  --help|-h)
    usage
    ;;
  --status)
    print_status_screen
    ;;
  --dry-run-cycles)
    shift
    if test "$#" -ne 1; then
      printf 'Please provide a cycle count from 1 to 3.\n' >&2
      exit 2
    fi
    run_dry_cycles "$1"
    ;;
  --print-latest-logs)
    print_latest_logs_list
    ;;
  --art)
    print_art
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac

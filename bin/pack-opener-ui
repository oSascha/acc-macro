  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⡾⣛⠻⢿⣦⠀⠀⠈⠈⢡⡜⣿⡿⠟⡿⠃⠀⣄⢳⣿⡿⣿⢿⡿⣿⣽⣿⣿⡿⣧⣿⣿⣷⣿⠛⢸⣿⣿⣿'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⣡⠻⡷⣦⡿⠆⠀⠀⢠⣦⠀⢸⡅⠰⠃⠘⣦⡾⣧⡏⡄⢣⡄⣀⣿⣛⣬⡅⣶⣿⣿⣿⣿⢹⡄⣻⣿⣯⣿'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⡠⠃⠀⢧⠀⣳⡀⠀⢠⣾⡿⠆⢈⣣⠀⠀⠀⡞⠃⠻⢀⠀⢾⣧⣉⣛⣉⣤⣶⣿⡟⠸⡌⢾⠀⣣⣿⡏⢫⡿'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⣾⣀⠀⠀⠙⠃⠘⠃⠠⣼⡇⠀⠀⢨⡖⠀⠀⠀⠁⠀⠀⠈⠁⠈⠻⢿⣿⣿⣿⠟⡹⠶⠁⡓⡘⣆⠿⠡⢠⡏⡿'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠈⠺⢗⣦⣄⣀⠀⠀⠀⠉⠀⠀⠀⠀⠀⠀⠀⠀⠀⣠⠤⠀⠀⠀⠀⣫⣿⣿⣿⠀⢧⢸⠀⡿⢰⢣⢸⡇⡜⣸⣼'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠉⠛⢮⣿⡟⡿⣿⡿⣿⡿⣿⠿⢻⡿⠟⢉⠀⠔⠁⠀⠀⠀⢿⣹⡟⣿⡄⣽⣿⢃⢣⢸⣮⢿⢼⢡⣿⣿'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠉⢻⣧⣵⣾⣾⣿⠿⢻⠇⢀⠔⠁⠀⡜⠐⠀⠄⢐⣿⣎⣿⡹⢷⡄⣿⣿⣼⢿⡟⢹⢀⣡⡽⣽'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢻⠀⣠⡾⢁⣴⣏⡠⠊⠀⡠⠊⠀⠀⣄⣀⣼⣇⠫⢢⡧⢘⣧⡽⣬⢷⡞⡷⡠⢳⢾⠣⡼'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣼⠖⠁⠀⢀⠟⡹⠋⠁⣴⠁⠀⠀⠀⣸⡟⠀⢦⣁⣬⢡⠷⣫⢵⡘⠸⠇⡷⠯⡍⠸⡔⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢘⡄⠀⠀⣼⣚⣁⣀⣞⣉⣀⣀⣴⣯⣾⣧⣴⣾⣿⣿⠊⠀⠈⠃⠹⠃⠀⠣⠀⠀⠀⢷⠤'
  printf '%s' "$GREY"
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢰⣾⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⡆⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢸⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣷⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣾⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⡇⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢀⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⡇⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣀⣴⣾⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⢀⣴⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⡦⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⢀⣴⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣷⡀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⣠⣾⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣧⡀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⣠⣾⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⡆⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⣠⣾⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣧⡀⠀⠀⠀⠀⠀⠀'
  printf '%s\n' "$RESET"
}

startup_pulse() {
  if test "$use_animation" -ne 1; then
    return
  fi
  clear_screen
  show_startup_eyes
  printf '%sACC LINKING.  %s\r' "$CYAN" "$RESET"
  sleep 0.3
  printf '%sACC LINKING.. %s\r' "$CYAN" "$RESET"
  sleep 0.3
  printf '%sACC LINKING...%s\r' "$CYAN" "$RESET"
  sleep 0.3
  printf '%sACC READY     %s\n' "$GREEN" "$RESET"
  sleep 0.5
}

status_color() {
  case "$1" in
    READY) printf '%s' "$CYAN" ;;
    "DRY RUN") printf '%s' "$YELLOW" ;;
    "LIVE ARMED") printf '%s' "$MAGENTA" ;;
    RUNNING) printf '%s' "$CYAN" ;;
    COMPLETE) printf '%s' "$GREEN" ;;
    FAILED) printf '%s' "$RED" ;;
    STOPPED) printf '%s' "$YELLOW" ;;
    *) printf '%s' "$RESET" ;;
  esac
}

# ── Main menu ─────────────────────────────────────────────────────────────────

main_menu() {
  local potion_state
  potion_state="$(on_off "$(plan_value POTION_PLAN_ENABLED)")"

  clear_screen
  small_logo
  printf '%s╔══════════════════════════════════════════════════════════════╗%s\n' "$MAGENTA" "$RESET"
  printf '%s║%s  %sACC // PACK OPENER%s                                         %s║%s\n' "$MAGENTA" "$RESET" "$BOLD$CYAN" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  %sSober / Gamescope Live Control%s                            %s║%s\n' "$MAGENTA" "$RESET" "$GREY" "$RESET" "$MAGENTA" "$RESET"
  printf '%s╠══════════════════════════════════════════════════════════════╣%s\n' "$MAGENTA" "$RESET"
  printf '%s║%s  Pack Opener: %s%-8s%s  Potions: %-3s  Cycle: base→potion→pack %s║%s\n' \
    "$MAGENTA" "$RESET" "$(status_color "$status_label")" "$status_label" "$RESET" "$potion_state" "$MAGENTA" "$RESET"
  printf '%s║%s  Stop: %sCtrl+C%s while running                                %s║%s\n' "$MAGENTA" "$RESET" "$YELLOW" "$RESET" "$MAGENTA" "$RESET"
  printf '%s╠══════════════════════════════════════════════════════════════╣%s\n' "$MAGENTA" "$RESET"
  printf '%s║%s  %s1) Start Full Macro%s                                        %s║%s\n' "$MAGENTA" "$RESET" "$BOLD" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  2) Module toggles                                         %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  3) Macro status                                           %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  4) Macro modules                                          %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  5) Advanced / Testing / Calibration                       %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"

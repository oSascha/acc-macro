#!/usr/bin/env bash
set -uo pipefail

ui_script="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
  resolved_ui_script="$(readlink -f "$ui_script" 2>/dev/null || printf '%s' "$ui_script")"
else
  resolved_ui_script="$ui_script"
fi
ui_bin_dir="$(cd "${resolved_ui_script%/*}" && pwd -P)"
PROJECT_ROOT="${ui_bin_dir%/bin}"
MACRO_PROJECT_ROOT="$PROJECT_ROOT"

RUNTIME_DIR="$PROJECT_ROOT/runtime_config/pack_opener"
TIMING_FILE="$RUNTIME_DIR/timing.conf"
POTION_PLAN_FILE="$RUNTIME_DIR/potion_plan.conf"
POINTS_FILE="$RUNTIME_DIR/points.conf"
MARKET_BUYER_POINTS_FILE="$PROJECT_ROOT/runtime_config/market_buyer/points.conf"
FIGURINES_BUYER_POINTS_FILE="$PROJECT_ROOT/runtime_config/figurines_buyer/points.conf"
LOG_DIR="$PROJECT_ROOT/05_debug_snapshots/logs"
METRICS_FILE="$PROJECT_ROOT/runtime_config/orchestrator/run_metrics.conf"
MACROCTL="$PROJECT_ROOT/bin/macroctl"

# ACC_DEBUG_LOGS=1 enables persistent log files for Full Macro (default: off).
ACC_DEBUG_LOGS="${ACC_DEBUG_LOGS:-0}"

# shellcheck source=../src/lib/orchestrator_control.sh
. "$PROJECT_ROOT/src/lib/orchestrator_control.sh"

interactive=0
if test -t 0 && test -t 1; then
  interactive=1
fi

colors_enabled=0
if test -t 1 && test -z "${NO_COLOR:-}"; then
  colors_enabled=1
fi

if test "$colors_enabled" -eq 1; then
  RESET=$'\033[0m'
  BOLD=$'\033[1m'
  DIM=$'\033[2m'
  CYAN=$'\033[96m'
  MAGENTA=$'\033[95m'
  GREEN=$'\033[92m'
  YELLOW=$'\033[93m'
  RED=$'\033[91m'
  GREY=$'\033[90m'
else
  RESET=''
  BOLD=''
  DIM=$''
  CYAN=''
  MAGENTA=''
  GREEN=''
  YELLOW=''
  RED=''
  GREY=''
fi

use_animation=0
if test "$interactive" -eq 1 && test "${ACC_NO_ANIMATION:-}" != "1"; then
  use_animation=1
fi

status_label="READY"
ACC_STOP_REQUESTED=0
_acc_full_macro_orch_pid=""
_full_macro_start_epoch=0

# Session-state module toggles (1 = enabled, 0 = disabled)
# Changed in module_toggles_loop(); passed as env vars to orchestrator.
TOGGLE_PACK_OPENER=1
TOGGLE_MARKET_BUYER=1
TOGGLE_FIGURINES_BUYER=1
TOGGLE_STAR_TRIALS=0
TOGGLE_RECOVERY_RESTART=0
TOGGLE_EVENT_VOTER=0

# Recovery config paths (read-only helpers for UI display)
RECOVERY_RUNTIME_DIR="$PROJECT_ROOT/runtime_config/recovery"
RECOVERY_DEFAULTS_FILE_UI="$RECOVERY_RUNTIME_DIR/defaults.conf"
RECOVERY_POINTS_FILE_UI="$RECOVERY_RUNTIME_DIR/points.conf"

EVENT_VOTER_DEFAULTS_FILE="$PROJECT_ROOT/runtime_config/event_voter/defaults.conf"

SOBER_LAUNCHER_DEFAULTS_FILE="$PROJECT_ROOT/runtime_config/sober_launcher/defaults.conf"

# shellcheck source=../src/modules/sober_launcher.sh
. "$PROJECT_ROOT/src/modules/sober_launcher.sh"

usage() {
  cat <<EOF
Usage: $0 [option]

ACC // PACK OPENER — Auto Cycle Controller

Options:
  --help              Show this help.
  --status            Show current status and exit.
  --dry-run-cycles N  Test without clicking for 1, 2, or 3 cycles.
  --print-latest-logs Show the latest saved logs and exit.
  --art               Show ACC art and exit.

Without options, opens the ACC menu.
Live runs are only available from the menu and require typed confirmation.
EOF
}

config_get() {
  local file="$1"
  local key="$2"
  local line

  line="$(grep -E "^${key}=" "$file" 2>/dev/null | tail -n1)" || true
  if test -z "$line"; then
    return 1
  fi
  printf '%s' "${line#*=}"
}

point_value() {
  local name="$1"
  local x
  local y

  x="$(config_get "$POINTS_FILE" "${name}_X" || true)"
  y="$(config_get "$POINTS_FILE" "${name}_Y" || true)"
  if test -n "$x" && test -n "$y"; then
    printf '%s,%s' "$x" "$y"
  else
    printf '<unset>'
  fi
}

timing_value() {
  local key="$1"
  config_get "$TIMING_FILE" "$key" || printf '<unset>'
}

plan_value() {
  local key="$1"
  config_get "$POTION_PLAN_FILE" "$key" || printf '<unset>'
}

on_off() {
  case "${1:-}" in
    1) printf 'on' ;;
    0) printf 'off' ;;
    *) printf '%s' "${1:-<unset>}" ;;
  esac
}

recovery_config_get() {
  local key="$1"
  local val
  val="$(config_get "$RECOVERY_DEFAULTS_FILE_UI" "$key" 2>/dev/null || true)"
  if test -z "$val"; then
    val="$(config_get "$RECOVERY_POINTS_FILE_UI" "$key" 2>/dev/null || true)"
  fi
  printf '%s' "$val"
}

recovery_url_configured() {
  local url
  url="$(recovery_config_get RECOVERY_PRIVATE_SERVER_URL)"
  test -n "$url"
}

recovery_required_points_configured() {
  local key val
  for key in RECOVERY_POPUP_CLOSE_BUTTON_X RECOVERY_POPUP_CLOSE_BUTTON_Y \
             RECOVERY_ITEMS_TAB_BUTTON_X RECOVERY_ITEMS_TAB_BUTTON_Y; do
    val="$(config_get "$RECOVERY_POINTS_FILE_UI" "$key" 2>/dev/null || true)"
    if test -z "$val"; then
      return 1
    fi
  done
  return 0
}

recovery_module_label() {
  local toggle="$1"
  local name="$2"
  if test "$toggle" != "1"; then
    printf '%s[OFF          ]%s %s\n' "$YELLOW" "$RESET" "$name"
  elif recovery_url_configured && recovery_required_points_configured; then
    printf '%s[READY        ]%s %s\n' "$GREEN" "$RESET" "$name"
  else
    printf '%s[NEEDS CONFIG ]%s %s\n' "$RED" "$RESET" "$name"
  fi
}

event_voter_config_get() {
  local key="$1"
  config_get "$EVENT_VOTER_DEFAULTS_FILE" "$key" 2>/dev/null || true
}

event_voter_status_label() {
  local toggle="$1"
  if test "$toggle" != "1"; then
    printf '%s[OFF          ]%s Event Voter\n' "$YELLOW" "$RESET"
    return
  fi
  local ev_enabled ev_live
  ev_enabled="$(event_voter_config_get EVENT_VOTER_ENABLED)"
  ev_live="$(event_voter_config_get EVENT_VOTER_LIVE_ALLOWED)"
  if test "${ev_enabled:-0}" != "1"; then
    printf '%s[NEEDS CONFIG ]%s Event Voter\n' "$RED" "$RESET"
  elif test "${ev_live:-0}" = "1"; then
    printf '%s[LIVE ARMED   ]%s Event Voter\n' "$GREEN" "$RESET"
  else
    printf '%s[READY        ]%s Event Voter\n' "$CYAN" "$RESET"
  fi
}

clear_screen() {
  if test "$interactive" -eq 1; then
    printf '\033[2J\033[H'
  fi
}

pause_return() {
  if test "$interactive" -eq 1; then
    printf '\nPress Enter to return.'
    read -r _unused
  fi
}

terminal_width() {
  local w
  w="$(tput cols 2>/dev/null)" || w=80
  printf '%s' "$w"
}

small_logo() {
  printf '%s   ___    ____   ____%s\n' "$CYAN" "$RESET"
  printf '%s  / _ |  / ___/ / ___/%s\n' "$CYAN" "$RESET"
  printf '%s / __ |  | |   | |   %s\n' "$CYAN" "$RESET"
  printf '%s/_/ |_|  \\___/  \\___/%s\n' "$CYAN" "$RESET"
  printf '%sAUTO CYCLE CONTROLLER%s\n' "$GREY" "$RESET"
}

print_art() {
  printf '%s' "$CYAN"
  cat <<'EOF'
   ___    ____   ____
  / _ |  / ___/ / ___/
 / __ |  | |   | |
/_/ |_|  \___/  \___/

AUTO CYCLE CONTROLLER
EOF
  printf '%s\n' "$RESET"
  printf '%sACC // PACK OPENER%s\n' "$MAGENTA" "$RESET"
  printf '%sSOBER / GAMESCOPE LIVE CONTROL%s\n' "$GREY" "$RESET"
}

show_startup_eyes() {
  local cols pad_count pad
  cols="$(terminal_width)"
  pad_count=$(( (cols - 50) / 2 ))
  [ "$pad_count" -lt 0 ] && pad_count=0
  pad="$(printf '%*s' "$pad_count" '')"

  printf '%s' "$MAGENTA"
  printf '%s%s\n' "$pad" '⠤⣤⣤⣤⣄⣀⣀⣀⣀⣀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣀⣀⣠⣤⠤⠤⠴⠶⠶⠶⠶'
  printf '%s%s\n' "$pad" '⢠⣤⣤⡄⣤⣤⣤⠄⣀⠉⣉⣙⠒⠤⣀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣠⠴⠘⣉⢡⣤⡤⠐⣶⡆⢶⠀⣶⣶⡦'
  printf '%s' "$CYAN"
  printf '%s%s\n' "$pad" '⣄⢻⣿⣧⠻⠇⠋⠀⠋⠀⢘⣿⢳⣦⣌⠳⠄⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠞⣡⣴⣧⠻⣄⢸⣿⣿⡟⢁⡻⣸⣿⡿⠁'
  printf '%s%s\n' "$pad" '⠈⠃⠙⢿⣧⣙⠶⣿⣿⡷⢘⣡⣿⣿⣿⣷⣄⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢠⣾⣿⣿⣿⣷⣝⡳⠶⠶⠾⣛⣵⡿⠋⠀⠀'
  printf '%s' "$MAGENTA"
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠉⠻⣿⣶⠂⠘⠛⠛⠛⢛⡛⠋⠉⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠉⠉⠉⠛⠀⠉⠒⠛⠀⠀⠀⠀⠀'
  printf '%s' "$GREY"
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⣿⡇⠀⠀⠀⠀⠀⢸⠃⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⣿⡇⠀⠀⠀⠀⠀⣾⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⣿⡇⠀⠀⠀⠀⠀⣿⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⢻⡁⠀⠀⠀⠀⠀⢸⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠘⡇⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⡇⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠿⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s\n' "$RESET"
}

show_running_side_profile() {
  local cols pad_count pad
  cols="$(terminal_width)"
  pad_count=$(( (cols - 48) / 2 ))
  [ "$pad_count" -lt 0 ] && pad_count=0
  pad="$(printf '%*s' "$pad_count" '')"

  clear_screen
  printf '%s' "$MAGENTA"
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⡟⢰⠀⠀⠀⠀⠀⠀⡄⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢡⠠⠀⠀⡇⣯⡄⢀⢀⢰⠢⡀⢣⠘⡄⠀⢀⡀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣀⠀⠀⠀⢂⠑⡀⡇⢿⠐⡈⠪⠄⣧⣐⣄⠿⡱⢄⠀⢺⠤⢀⢰⣀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⡤⣀⠀⠑⢦⡤⢤⣥⡬⢧⠼⢧⠬⠯⡙⣷⣖⠧⡙⣒⣧⠵⣀⠩⣢⢿⣌⢓⢄⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s' "$CYAN"
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠐⢄⠳⡌⠙⠡⣍⡓⠦⣌⠭⢬⣤⣡⠐⢎⢼⠷⢞⣼⣬⣱⣽⣲⢫⢻⢕⣍⠣⡱⡽⡲⡠⣀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⡀⢕⡢⢈⠣⡾⢌⡃⠠⢘⣧⣋⠙⠦⡭⢭⡝⠶⣳⠷⢮⣽⣶⣷⣭⣹⢷⡷⣿⣯⣷⡨⢶⣿⣵⢌⡦⡀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⢀⢈⠢⣹⣢⣨⠖⢍⡒⠶⠨⣡⣒⣷⣶⣭⡗⣚⠚⡭⠝⠴⠦⣤⠍⣛⣓⢯⣬⣿⣽⣽⡿⣿⣿⣮⣾⡽⢷⣲⢱⡀⢀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠈⢋⢼⢽⢯⢦⡙⣓⠞⡛⣳⣙⣾⣭⣧⣄⣀⠤⠐⠒⠉⠊⠙⢛⣿⣟⣯⣾⣭⣻⣮⣻⣿⣿⣿⣿⣿⣦⠘⣞⡌⡿⣼'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⣱⢻⡔⢤⣉⣐⣤⣋⣥⡤⣽⡷⠒⠌⡀⢀⣠⡤⠚⢈⣉⡴⠯⠛⠻⢃⢛⣻⣿⣷⣿⣿⡿⣿⣿⣿⣧⣿⣶⣲⢻'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠑⠺⢅⣝⣛⣥⣍⡁⢀⣉⣠⣴⠞⣋⣽⠡⢴⠾⣋⡡⢄⣲⣈⠭⠙⠛⣻⣿⣿⣷⣿⣿⣽⣿⣿⣿⣿⣿⣿⣿'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠒⡤⢤⢶⠚⣋⡩⢤⣖⣍⣉⣾⢋⣬⣛⣷⡿⠋⣨⣕⣦⠓⠁⠀⣀⠴⢎⣉⠵⢛⣻⣩⣽⣿⣿⣿⣿⣿⣿⣋⣟'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⣴⣙⡽⣯⡝⣋⣡⣴⣤⢿⢡⣿⣿⡿⢊⣤⠾⠋⡩⠂⢀⣴⡫⠕⣊⠕⢁⠔⢁⡼⠋⠁⡁⣸⣿⣿⣿⣿⣛⣿'

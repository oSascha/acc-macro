  printf '%s║%s  1)  Show status                                           %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  2)  Test without clicking %s(dry run, 1 cycle)%s              %s║%s\n' "$MAGENTA" "$RESET" "$GREY" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  3)  Run once                                              %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  4)  Run twice                                             %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  5)  Run three times                                       %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  6)  Run with timing trace %s(dry run, 1 cycle)%s              %s║%s\n' "$MAGENTA" "$RESET" "$GREY" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  7)  Potion settings                                       %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  8)  Calibrate buttons                                     %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  9)  Adjust walking path                                   %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  10) Show latest logs                                      %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  11) Project status                                        %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  b)  Back                                                  %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"
  printf '%s╚══════════════════════════════════════════════════════════════╝%s\n' "$MAGENTA" "$RESET"
  printf '\nChoose: '
}

# ── Status / info screens ─────────────────────────────────────────────────────

changed_summary() {
  local out
  out="$(git -C "$PROJECT_ROOT" status --short 2>/dev/null || true)"
  if test -z "$out"; then
    printf 'clean'
  else
    printf 'has changes'
  fi
}


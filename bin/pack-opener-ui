        run_dry_cycles 1
        pause_return
        ;;
      3)
        clear_screen
        run_live_cycles 1
        pause_return
        ;;
      4)
        clear_screen
        run_live_cycles 2
        pause_return
        ;;
      5)
        clear_screen
        run_live_cycles 3
        pause_return
        ;;
      6)
        clear_screen
        run_dry_cycles_with_trace 1
        pause_return
        ;;
      7)
        clear_screen
        launch_potion_settings
        pause_return
        ;;
      8)
        clear_screen
        launch_button_calibration
        pause_return
        ;;

  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢡⢠⡄⠀⠀⡘⢩⠗⢪⢋⡟⣐⠥⠶⣹⠼⠑⢈⣀⣴⠜⢁⠀⠀⢠⡕⣽⠀⣟⣾⣿⢻⢻⣿⣿⣿⣿'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⢀⣠⠚⡁⠋⠀⠠⡦⠢⠴⢥⣎⣜⣡⣶⣾⣶⣾⣿⣭⣽⣠⠴⢃⣔⣪⡞⣱⣷⠸⣼⣟⣧⣟⣼⣟⣿⣿⣿'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⢸⡟⣷⡀⠀⠀⠀⣧⢠⡔⢋⣡⣾⣿⣿⢻⡏⠛⢻⣿⡟⢁⣴⣫⢻⣿⣲⣿⣾⡀⣷⣛⡟⣬⣿⢹⣿⣿⣿'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⡾⣛⠻⢿⣦⠀⠀⠈⠈⢡⡜⣿⡿⠟⡿⠃⠀⣄⢳⣿⡿⣿⢿⡿⣿⣽⣿⣿⡿⣧⣿⣿⣷⣿⠛⢸⣿⣿⣿'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⣡⠻⡷⣦⡿⠆⠀⠀⢠⣦⠀⢸⡅⠰⠃⠘⣦⡾⣧⡏⡄⢣⡄⣀⣿⣛⣬⡅⣶⣿⣿⣿⣿⢹⡄⣻⣿⣯⣿'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⡠⠃⠀⢧⠀⣳⡀⠀⢠⣾⡿⠆⢈⣣⠀⠀⠀⡞⠃⠻⢀⠀⢾⣧⣉⣛⣉⣤⣶⣿⡟⠸⡌⢾⠀⣣⣿⡏⢫⡿'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⣾⣀⠀⠀⠙⠃⠘⠃⠠⣼⡇⠀⠀⢨⡖⠀⠀⠀⠁⠀⠀⠈⠁⠈⠻⢿⣿⣿⣿⠟⡹⠶⠁⡓⡘⣆⠿⠡⢠⡏⡿'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠈⠺⢗⣦⣄⣀⠀⠀⠀⠉⠀⠀⠀⠀⠀⠀⠀⠀⠀⣠⠤⠀⠀⠀⠀⣫⣿⣿⣿⠀⢧⢸⠀⡿⢰⢣⢸⡇⡜⣸⣼'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠉⠛⢮⣿⡟⡿⣿⡿⣿⡿⣿⠿⢻⡿⠟⢉⠀⠔⠁⠀⠀⠀⢿⣹⡟⣿⡄⣽⣿⢃⢣⢸⣮⢿⢼⢡⣿⣿'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠉⢻⣧⣵⣾⣾⣿⠿⢻⠇⢀⠔⠁⠀⡜⠐⠀⠄⢐⣿⣎⣿⡹⢷⡄⣿⣿⣼⢿⡟⢹⢀⣡⡽⣽'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢻⠀⣠⡾⢁⣴⣏⡠⠊⠀⡠⠊⠀⠀⣄⣀⣼⣇⠫⢢⡧⢘⣧⡽⣬⢷⡞⡷⡠⢳⢾⠣⡼'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣼⠖⠁⠀⢀⠟⡹⠋⠁⣴⠁⠀⠀⠀⣸⡟⠀⢦⣁⣬⢡⠷⣫⢵⡘⠸⠇⡷⠯⡍⠸⡔⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢘⡄⠀⠀⣼⣚⣁⣀⣞⣉⣀⣀⣴⣯⣾⣧⣴⣾⣿⣿⠊⠀⠈⠃⠹⠃⠀⠣⠀⠀⠀⢷⠤'
  printf '%s' "$GREY"
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢰⣾⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⡆⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢸⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣷⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣾⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⡇⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢀⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⡇⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣀⣴⣾⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⠀⠀⢀⣴⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⡦⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⠀⠀⢀⣴⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣷⡀⠀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⠀⠀⣠⣾⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣧⡀⠀⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⠀⠀⣠⣾⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⡆⠀⠀⠀⠀⠀⠀⠀'
  printf '%s%s\n' "$pad" '⣠⣾⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣧⡀⠀⠀⠀⠀⠀⠀'
  printf '%s\n' "$RESET"
}

# ── Live dashboard renderer ───────────────────────────────────────────────────
#
# Box geometry:  total width = 56  (╔ + 54×═ + ╗)
#   interior:    54 chars  = 2 lead + 18 label + 2 gap + 30 value + 2 trail
#
_DASH_LABEL_W=18
_DASH_VALUE_W=30

# Strip ANSI escape sequences from a string (for visible-length measurement).
strip_ansi() {
  printf '%s' "$1" | sed $'s/\033\\[[0-9;]*m//g'
}

# Print a full-width separator line (╠═…═╣).
dashboard_sep() {
  printf '%s╠══════════════════════════════════════════════════════╣%s\n' \
    "$MAGENTA" "$RESET"
}

# Print one content row with a left-aligned label and a left-aligned value.
# $1 = plain label text   (no ANSI; padded to _DASH_LABEL_W)
# $2 = plain visible value (no ANSI; padded to _DASH_VALUE_W)
# $3 = optional color prefix applied to the value field
# $4 = optional color suffix (reset) applied after the value field
dashboard_row() {
  local label="$1" value="$2" vpre="${3:-}" vsuf="${4:-}"
  local label_str value_str
  printf -v label_str '%-*s' "$_DASH_LABEL_W" "$label"
  printf -v value_str '%-*s' "$_DASH_VALUE_W" "$value"
  # Interior visible chars: 2 + 18 + 2 + 30 + 2 = 54  ✓
  printf '%s║%s  %s  %s%s%s  %s║%s\n' \
    "$MAGENTA" "$RESET" "$label_str" "$vpre" "$value_str" "$vsuf" "$MAGENTA" "$RESET"
}

# Print a header line (text starts after 2-space indent, right side padded).
# $1 = plain text   $2 = color prefix (opt)   $3 = color suffix (opt)
dashboard_header() {
  local text="$1" pre="${2:-}" suf="${3:-}"
  local tlen="${#text}"
  # inner=54, lead=2  →  trailing pad = 54 - 2 - tlen
  local pad_count=$(( 54 - 2 - tlen ))
  local pad_str
  printf -v pad_str '%*s' "$pad_count" ''
  printf '%s║%s  %s%s%s%s%s║%s\n' \
    "$MAGENTA" "$RESET" "$pre" "$text" "$suf" "$pad_str" "$MAGENTA" "$RESET"
}

# Print the controls line for the current view and orchestrator state.
# Uses \r\033[2K so it works both as a fresh line (after dashboard/art redraw)
# and as an in-place update while staying on the same terminal line.
print_live_controls_line() {
  local view="$1"    # "art" or "dash"
  local state="$2"   # running / pause_requested / paused / continue_requested
  case "$state" in
    running)
      if test "$view" = "dash"; then
        printf '\r\033[2K%sControls: d = art | p = pause after current loop | Ctrl+C = stop%s' \
          "$DIM" "$RESET"
      else
        printf '\r\033[2K%sControls: d = dashboard | p = pause after current loop | Ctrl+C = stop%s' \
          "$DIM" "$RESET"
      fi
      ;;
    pause_requested)
      printf '\r\033[2K%sControls: d = toggle view | pause requested — will pause after current loop | Ctrl+C = stop%s' \
        "$YELLOW" "$RESET"
      ;;
    paused)
      printf '\r\033[2K%sControls: d = toggle view | c = continue | Ctrl+C = stop%s' \
        "$CYAN" "$RESET"
      ;;
    continue_requested)
      printf '\r\033[2K%sControls: d = toggle view | resuming... | Ctrl+C = stop%s' \
        "$DIM" "$RESET"
      ;;
    *)
      printf '\r\033[2K%sControls: Ctrl+C = stop%s' "$DIM" "$RESET"
      ;;
  esac
}

# Read the run_metrics.conf file into _dash_* globals.
# Called once per dashboard refresh — never inside click/sleep hot paths.
_dash_read_metrics() {
  _dash_cycles=0
  _dash_bpc=13
  _dash_last_phase=""
  _dash_last_event=""
  _dash_market=0
  _dash_figurines=0
  _dash_recovery=0
  _dash_started_epoch=0
  _dash_ev_enabled=0
  _dash_last_ev_vote=""

  if ! test -f "$METRICS_FILE"; then
    return 0
  fi

  local k v
  while IFS='=' read -r k v; do
    case "$k" in
      COMPLETED_PACK_CYCLES) _dash_cycles="$v" ;;
      BUNDLES_PER_CYCLE)     _dash_bpc="$v" ;;
      LAST_PHASE)            _dash_last_phase="$v" ;;
      LAST_EVENT)            _dash_last_event="$v" ;;
      MARKET_RUNS)           _dash_market="$v" ;;
      FIGURINES_RUNS)        _dash_figurines="$v" ;;
      RECOVERY_RUNS)         _dash_recovery="$v" ;;
      RUN_STARTED_AT_EPOCH)  _dash_started_epoch="$v" ;;
      EVENT_VOTER_ENABLED)   _dash_ev_enabled="$v" ;;
      LAST_EVENT_VOTE)       _dash_last_ev_vote="$v" ;;
    esac
  done < "$METRICS_FILE" 2>/dev/null || true
}

show_live_dashboard() {
  local run_start_epoch="$1"
  local ctrl_state="$2"

  _dash_read_metrics

  # Runtime clock (prefer epoch from metrics file when available)
  local epoch_for_calc="$run_start_epoch"
  if test "${_dash_started_epoch:-0}" -gt 0; then
    epoch_for_calc="$_dash_started_epoch"
  fi

  local now_epoch elapsed h m s run_time_str
  now_epoch="$(date +%s)"
  elapsed=$(( now_epoch - epoch_for_calc ))
  test "$elapsed" -lt 0 && elapsed=0
  h=$(( elapsed / 3600 ))
  m=$(( (elapsed % 3600) / 60 ))
  s=$(( elapsed % 60 ))
  printf -v run_time_str '%02d:%02d:%02d' "$h" "$m" "$s"

  local estimated_bundles=$(( _dash_cycles * _dash_bpc ))

  local pause_str pause_color
  case "$ctrl_state" in
    running)            pause_str="RUNNING";         pause_color="$GREEN" ;;
    pause_requested)    pause_str="PAUSE REQUESTED"; pause_color="$YELLOW" ;;
    paused)             pause_str="PAUSED";          pause_color="$YELLOW" ;;
    continue_requested) pause_str="RESUMING";        pause_color="$CYAN" ;;
    *)                  pause_str="UNKNOWN";         pause_color="$GREY" ;;
  esac

  local debug_str
  if test "${ACC_DEBUG_LOGS:-0}" = "1"; then
    debug_str="ON  (ACC_DEBUG_LOGS=1)"
  else
    debug_str="OFF"
  fi

  local last_info="${_dash_last_phase:----}"
  if test -n "${_dash_last_event:-}"; then
    last_info="${_dash_last_phase:----} / ${_dash_last_event}"
  fi

  # Module toggle labels (plain visible text; colors passed separately)
  local pack_lbl market_lbl fig_lbl rec_lbl
  local pack_col market_col fig_col rec_col
  if test "$TOGGLE_PACK_OPENER"       = "1"; then pack_lbl="[ON ]";  pack_col="$GREEN";  else pack_lbl="[OFF]";  pack_col="$YELLOW"; fi
  if test "$TOGGLE_MARKET_BUYER"      = "1"; then market_lbl="[ON ]"; market_col="$GREEN"; else market_lbl="[OFF]"; market_col="$YELLOW"; fi
  if test "$TOGGLE_FIGURINES_BUYER"   = "1"; then fig_lbl="[ON ]";   fig_col="$GREEN";   else fig_lbl="[OFF]";   fig_col="$YELLOW"; fi
  if test "$TOGGLE_RECOVERY_RESTART"  = "1"; then rec_lbl="[ON ]";   rec_col="$GREEN";   else rec_lbl="[OFF]";   rec_col="$YELLOW"; fi
  local ev_lbl ev_col
  if test "$TOGGLE_EVENT_VOTER" = "1"; then ev_lbl="[ON ]"; ev_col="$GREEN"; else ev_lbl="[OFF]"; ev_col="$YELLOW"; fi

  local buyer_str
  printf -v buyer_str 'Market: %s  Figurines: %s' "$_dash_market" "$_dash_figurines"

  clear_screen
  printf '%s╔══════════════════════════════════════════════════════╗%s\n' "$MAGENTA" "$RESET"
  dashboard_header "ACC // LIVE DASHBOARD" "$BOLD$CYAN" "$RESET"
  dashboard_sep
  dashboard_row "Run time"      "$run_time_str"
  dashboard_row "Pack cycles"   "$_dash_cycles"
  dashboard_row "Bundles/cycle" "$_dash_bpc"
  dashboard_row "Est. bundles"  "$estimated_bundles" "$BOLD$CYAN" "$RESET"
  dashboard_sep
  dashboard_row "Status"     "$pause_str"  "$pause_color" "$RESET"
  dashboard_row "Last event" "$last_info"
  dashboard_sep
  dashboard_row "Pack Opener"      "$pack_lbl"   "$pack_col"   "$RESET"
  dashboard_row "Market Buyer"     "$market_lbl" "$market_col" "$RESET"
  dashboard_row "Figurines Buyer"  "$fig_lbl"    "$fig_col"    "$RESET"
  dashboard_row "Recovery Restart" "$rec_lbl"    "$rec_col"    "$RESET"
  dashboard_row "Event Voter"      "$ev_lbl"     "$ev_col"     "$RESET"
  dashboard_sep
  dashboard_row "Buyer runs"    "$buyer_str"
  dashboard_row "Recovery runs" "$_dash_recovery"
  if test "${_dash_ev_enabled:-0}" = "1"; then
    dashboard_row "Event Voter" "${_dash_last_ev_vote:----}"
  fi
  dashboard_row "Debug logs"    "$debug_str"
  printf '%s╚══════════════════════════════════════════════════════╝%s\n' "$MAGENTA" "$RESET"
}

startup_pulse() {
  if test "$use_animation" -ne 1; then
    return
  fi
  clear_screen
  show_startup_eyes
  printf '%sACC LINKING.  %s\r' "$CYAN" "$RESET"
  sleep 0.3
  printf '%sACC LINKING.. %s\r' "$CYAN" "$RESET"
  sleep 0.3
  printf '%sACC LINKING...%s\r' "$CYAN" "$RESET"
  sleep 0.3
  printf '%sACC READY     %s\n' "$GREEN" "$RESET"
  sleep 0.5
}

status_color() {
  case "$1" in
    READY) printf '%s' "$CYAN" ;;
    "DRY RUN") printf '%s' "$YELLOW" ;;
    "LIVE ARMED") printf '%s' "$MAGENTA" ;;
    RUNNING) printf '%s' "$CYAN" ;;
    COMPLETE) printf '%s' "$GREEN" ;;
    FAILED) printf '%s' "$RED" ;;
    STOPPED) printf '%s' "$YELLOW" ;;
    *) printf '%s' "$RESET" ;;
  esac
}

# ── Main menu ─────────────────────────────────────────────────────────────────

main_menu() {
  local potion_state
  potion_state="$(on_off "$(plan_value POTION_PLAN_ENABLED)")"

  clear_screen
  small_logo
  printf '%s╔══════════════════════════════════════════════════════════════╗%s\n' "$MAGENTA" "$RESET"
  printf '%s║%s  %sACC // PACK OPENER%s                                          %s║%s\n' "$MAGENTA" "$RESET" "$BOLD$CYAN" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  %sSober / Gamescope Live Control%s                              %s║%s\n' "$MAGENTA" "$RESET" "$GREY" "$RESET" "$MAGENTA" "$RESET"
  printf '%s╠══════════════════════════════════════════════════════════════╣%s\n' "$MAGENTA" "$RESET"
  printf '%s║%s  Pack Opener: %s%-8s%s  Potions: %-3s  Cycle: base→potion→pack%s║%s\n' \
    "$MAGENTA" "$RESET" "$(status_color "$status_label")" "$status_label" "$RESET" "$potion_state" "$MAGENTA" "$RESET"
  printf '%s║%s  Stop: %sCtrl+C%s while running                                  %s║%s\n' "$MAGENTA" "$RESET" "$YELLOW" "$RESET" "$MAGENTA" "$RESET"
  printf '%s╠══════════════════════════════════════════════════════════════╣%s\n' "$MAGENTA" "$RESET"
  printf '%s║%s  %s1) Sober Instance%s                                           %s║%s\n' "$MAGENTA" "$RESET" "$BOLD" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  %s2) Start Full Macro%s                                         %s║%s\n' "$MAGENTA" "$RESET" "$BOLD" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  3) Module toggles                                           %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  4) Macro status                                             %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  5) Macro modules                                            %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  6) Advanced / Testing / Calibration                         %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"
  printf '%s║%s  q) Quit                                                     %s║%s\n' "$MAGENTA" "$RESET" "$MAGENTA" "$RESET"
  printf '%s╚══════════════════════════════════════════════════════════════╝%s\n' "$MAGENTA" "$RESET"
  printf '\nChoose: '
}

# ── Advanced / Testing / Calibration submenu ──────────────────────────────────

advanced_menu() {
  clear_screen
  small_logo
  printf '%s╔══════════════════════════════════════════════════════════════╗%s\n' "$MAGENTA" "$RESET"
  printf '%s║%s  %sADVANCED / TESTING / CALIBRATION%s                          %s║%s\n' "$MAGENTA" "$RESET" "$BOLD$CYAN" "$RESET" "$MAGENTA" "$RESET"

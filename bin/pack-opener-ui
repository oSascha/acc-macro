# ── Sober Instance submenu ───────────────────────────────────────────────────

_sober_ui_status_color() {
  local status="$1"
  case "$status" in
    live)           printf '%s' "$GREEN" ;;
    live_untracked) printf '%s' "$YELLOW" ;;
    offline)        printf '%s' "$GREY" ;;
    *)              printf '%s' "$RESET" ;;
  esac
}

_sober_ui_status_label() {
  local status="$1"
  case "$status" in
    live)           printf 'Live' ;;
    live_untracked) printf 'Live (untracked)' ;;
    offline)        printf 'Offline' ;;
    *)              printf '%s' "$status" ;;
  esac
}

# ── Sober submenu box helpers ─────────────────────────────────────────────────
# Fixed inner width matching the main menu box (62 visible chars between ║ and ║).
_SOBER_BOX_INNER=62
_SOBER_BOX_RULE='══════════════════════════════════════════════════════════════'

# Strip ANSI escape sequences from a string (for visible-length measurement).
_sober_strip_ansi() {
  printf '%s' "$1" | sed $'s/\033\\[[0-9;]*m//g'
}

# Compute visible (non-ANSI) length of a string.
_sober_vis_len() {
  local s
  s="$(_sober_strip_ansi "$1")"
  printf '%s' "${#s}"
}

# Pad content (which may contain ANSI codes) to exactly _SOBER_BOX_INNER visible chars.
_sober_pad() {
  local content="$1"
  local vlen pad
  vlen="$(_sober_vis_len "$content")"
  pad=$(( _SOBER_BOX_INNER - vlen ))
  if test "$pad" -gt 0; then
    printf '%s%*s' "$content" "$pad" ''
  else
    printf '%s' "$content"
  fi
}

# Print a box content row: MAGENTA║RESET + padded content + MAGENTA║RESET
_sober_box_line() {
  printf '%s║%s%s%s║%s\n' \
    "$MAGENTA" "$RESET" "$(_sober_pad "$1")" "$MAGENTA" "$RESET"
}

_sober_box_top()    { printf '%s╔%s╗%s\n' "$MAGENTA" "$_SOBER_BOX_RULE" "$RESET"; }
_sober_box_divider(){ printf '%s╠%s╣%s\n' "$MAGENTA" "$_SOBER_BOX_RULE" "$RESET"; }
_sober_box_bottom() { printf '%s╚%s╝%s\n' "$MAGENTA" "$_SOBER_BOX_RULE" "$RESET"; }

print_sober_instance_menu() {
  local sl_status sl_url_status sl_size sl_status_colored

  MACRO_PROJECT_ROOT="$PROJECT_ROOT"
  sober_launcher_load_config

  sl_status="$(sober_launcher_status)"
  sl_status_colored="$(_sober_ui_status_color "$sl_status")$(_sober_ui_status_label "$sl_status")$RESET"
  if sober_launcher_has_private_url; then
    sl_url_status="Configured"
  else
    sl_url_status="${RED}Missing${RESET}"
  fi
  sl_size="${_sl_width}x${_sl_height}"

  clear_screen
  small_logo
  _sober_box_top
  _sober_box_line "  ${BOLD}${CYAN}Sober Instance${RESET}"
  _sober_box_divider
  _sober_box_line "  Status:              $sl_status_colored"
  _sober_box_line "  Private server link: $sl_url_status"
  _sober_box_line "  Launch mode:         Browser handoff + Sober in Gamescope"
  _sober_box_line "  Gamescope size:      $sl_size"
  _sober_box_divider
  _sober_box_line "  1) Start Sober normally"
  _sober_box_line "  2) Open configured private server"
  _sober_box_line "  3) Stop current Sober instance"
  _sober_box_line "  4) Back"
  _sober_box_bottom
  printf '\nChoose: '
}

sober_instance_loop() {
  local choice sl_status

  while true; do
    print_sober_instance_menu
    read -r choice
    MACRO_PROJECT_ROOT="$PROJECT_ROOT"
    sober_launcher_load_config
    case "$choice" in
      1)
        # ── Start Sober normally ────────────────────────────────────────────
        clear_screen
        sl_status="$(sober_launcher_status)"
        if test "$sl_status" = "live" || test "$sl_status" = "live_untracked"; then
          printf '%sAn instance is already running (%s).%s\n' \
            "$YELLOW" "$(_sober_ui_status_label "$sl_status")" "$RESET"
          printf 'Stop it and start a new one? [y/N] '
          local typed
          read -r typed
          case "${typed:-}" in
            y|Y|yes|YES)
              printf 'Stopping current instance...\n'
              sober_launcher_stop
              sleep 1
              ;;
            *)
              printf 'Cancelled.\n'
              pause_return
              continue
              ;;
          esac
        fi
        printf 'Starting Sober normally...\n'
        sober_launcher_start_normal
        pause_return
        ;;
      2)
        # ── Open configured private server ──────────────────────────────────
        clear_screen
        if ! sober_launcher_has_private_url; then
          printf '%sERROR: Private server URL is not configured.%s\n' "$RED" "$RESET"
          printf 'Set SOBER_PRIVATE_SERVER_URL in:\n'
          printf '  %s/runtime_config/sober_launcher/defaults.conf\n' "$PROJECT_ROOT"
          printf 'See docs/SOBER_INSTANCE_LAUNCHER.md for setup instructions.\n'
          pause_return
          continue
        fi
        sl_status="$(sober_launcher_status)"
        printf 'This opens the Roblox private-server page in your browser.\n'
        printf 'Your browser may ask to open a roblox-player link — that protocol\n'
        printf 'handoff will launch/join Sober in Gamescope by itself.\n'
        printf 'Select "Always allow %s to open roblox-player links" to skip future prompts.\n' \
          "https://www.roblox.com"
        printf '\n'
        if test "$sl_status" = "live" || test "$sl_status" = "live_untracked"; then
          printf '%sNote: Sober is already running (%s).%s\n' \
            "$YELLOW" "$(_sober_ui_status_label "$sl_status")" "$RESET"
          printf 'Opening the link may launch a new Sober session through the protocol handler.\n\n'
        fi
        printf 'Open configured private server link now? [y/N] '
        local typed_open
        read -r typed_open
        case "${typed_open:-}" in
          y|Y|yes|YES)
            sober_launcher_open_private_server
            ;;
          *)
            printf 'Cancelled.\n'
            ;;
        esac
        pause_return
        ;;
      3)
        # ── Stop current Sober instance ─────────────────────────────────────
        clear_screen
        sl_status="$(sober_launcher_status)"
        if test "$sl_status" = "offline"; then
          printf 'No Sober instance appears to be running.\n'
          pause_return
          continue
        fi
        if test "$sl_status" = "live_untracked"; then
          printf '%sInstance is Live (untracked) — not managed by this launcher.%s\n' "$YELLOW" "$RESET"
          printf 'Stop it anyway? [y/N] '
          local typed_stop
          read -r typed_stop
          case "${typed_stop:-}" in
            y|Y|yes|YES) ;;
            *)
              printf 'Cancelled.\n'
              pause_return
              continue
              ;;
          esac
        else
          printf 'Stopping Sober instance...\n'
        fi
        sober_launcher_stop
        pause_return
        ;;
      4|b|B)
        return
        ;;
      *)
        printf 'Please choose 1-4, or b to go back.\n'
        pause_return
        ;;
    esac
  done
}

